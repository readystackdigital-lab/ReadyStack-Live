  <slot />

  <CookieConsent />
  <CartDrawer />

  <script src="/js/main.js" is:inline></script>
  <script src="/js/animations.js" is:inline></script>
  <script src="/js/dashboard.js" is:inline></script>
  <script src={import.meta.env.DEV ? "http://localhost:8787/widget.js" : "https://agent.readystackdigital.com/widget.js"} async is:inline></script>
 </body>
</html>
