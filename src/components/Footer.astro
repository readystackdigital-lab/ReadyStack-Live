<style>
  /* ── Footer: 3-column layout (brand · founder · nav) on desktop ─ */
  @media (min-width: 901px) {
    #footer :global(.footer-top) {
      grid-template-columns: 1.15fr 0.8fr 1.15fr;
      align-items: start;
    }
  }

  /* ── Founder block ─────────────────────────────────────── */
  .footer-founder {
    /* adjust the whole block size here */
    --orb-size: 104px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.9rem;
    text-align: center;
    align-self: center;
  }
  .founder-text { display: flex; flex-direction: column; gap: 0.15rem; }
  .founder-kicker {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--amber);
  }
  .founder-name {
    font-family: var(--font-display);
    font-weight: var(--weight-bold);
    font-size: 1.15rem;
    letter-spacing: -0.02em;
    color: #fff;
  }

  /* ── 3D animated orb (no photo/icon) — size via --orb-size ─ */
  .founder-orb {
    position: relative;
    width: var(--orb-size);
    height: var(--orb-size);
    flex-shrink: 0;
    perspective: 600px;
    transform-style: preserve-3d;
    animation: orb-float 6s ease-in-out infinite;
  }
  @keyframes orb-float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-7px); } }

  .orb-core {
    position: absolute;
    inset: 17%;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      radial-gradient(circle at 32% 28%, rgba(255,255,255,0.22), transparent 42%),
      radial-gradient(circle at 68% 72%, rgba(245,158,11,0.35), transparent 55%),
      linear-gradient(150deg, #1b2027, #0d1014);
    border: 1px solid rgba(245,158,11,0.3);
    box-shadow:
      inset 0 2px 10px rgba(255,255,255,0.12),
      inset 0 -8px 18px rgba(0,0,0,0.5),
      0 18px 40px rgba(0,0,0,0.35);
    animation: orb-tilt 7s ease-in-out infinite;
  }
  @keyframes orb-tilt {
    0%,100% { transform: rotateX(8deg) rotateY(-12deg); }
    50%     { transform: rotateX(-6deg) rotateY(12deg); }
  }
  .orb-monogram {
    font-family: var(--font-display);
    font-weight: var(--weight-bold);
    font-size: calc(var(--orb-size) * 0.26);
    letter-spacing: -0.03em;
    background: linear-gradient(135deg, #FCD34D, #F59E0B);
    -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent;
    text-shadow: 0 0 24px rgba(245,158,11,0.4);
  }

  .orb-ring { position: absolute; inset: 0; border-radius: 50%; border: 1.5px solid transparent; }
  .orb-ring-1 { border-top-color: rgba(245,158,11,0.85); border-right-color: rgba(245,158,11,0.25); animation: orb-spin 4.5s linear infinite; }
  .orb-ring-2 { inset: 8px; border-bottom-color: rgba(16,185,129,0.7); border-left-color: rgba(16,185,129,0.2); animation: orb-spin 6.5s linear infinite reverse; }
  .orb-ring-3 { inset: -7px; border-top-color: rgba(255,255,255,0.5); border-left-color: rgba(255,255,255,0.12); animation: orb-spin 9s linear infinite; }
  @keyframes orb-spin { to { transform: rotate(360deg); } }

  .orb-spark { position: absolute; top: 50%; left: 50%; width: 100%; height: 100%; transform: translate(-50%,-50%); animation: orb-spin 5.5s linear infinite; }
  .orb-spark::before {
    content: ""; position: absolute; top: -3px; left: 50%;
    width: 8px; height: 8px; border-radius: 50%;
    background: #FCD34D; box-shadow: 0 0 12px 2px rgba(245,158,11,0.8);
    transform: translateX(-50%);
  }
  .orb-glow {
    position: absolute; inset: -20%; border-radius: 50%; z-index: -1;
    background: radial-gradient(circle, rgba(245,158,11,0.22), transparent 60%);
    filter: blur(14px);
    animation: orb-pulse 4s ease-in-out infinite;
  }
  @keyframes orb-pulse { 0%,100% { opacity: 0.7; } 50% { opacity: 1; } }

  /* Stacked footer (≤900px): keep founder centred, a touch smaller */
  @media (max-width: 900px) {
    .footer-founder { --orb-size: 96px; margin-block: 0.5rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .founder-orb, .orb-core, .orb-ring, .orb-spark, .orb-glow { animation: none !important; }
    .orb-core { transform: rotateX(6deg) rotateY(-10deg); }
  }
</style>
