</div>

<style>
  /* ── Footer: 3-column layout (brand · founder · nav) on desktop ─ */
  @media (min-width: 901px) {
    #footer :global(.footer-top) {
      grid-template-columns: 1.15fr 0.8fr 1.15fr;
      align-items: start;
    }
  }

  /* ── Founder block ─────────────────────────────────────── */
  .footer-founder {
    /* adjust the whole block size here */
    --orb-size: 104px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.9rem;
    text-align: center;
    align-self: center;
  }
  .founder-text { display: flex; flex-direction: column; align-items: center; gap: 0.15rem; }
  .founder-kicker {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--amber);
  }
  .founder-name {
    font-family: var(--font-display);
    font-weight: var(--weight-bold);
    font-size: 1.15rem;
    letter-spacing: -0.02em;
    color: #fff;
  }

  /* ── Founder photo — size via --orb-size ─ */
  .founder-photo-wrap {
    position: relative;
    width: var(--orb-size);
    height: var(--orb-size);
    flex-shrink: 0;
    animation: orb-float 6s ease-in-out infinite;
  }
  @keyframes orb-float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-6px); } }

  .founder-photo {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
    border: 2px solid rgba(245,158,11,0.55);
    box-shadow:
      0 18px 40px rgba(0,0,0,0.45),
      inset 0 0 0 1px rgba(255,255,255,0.06);
  }

  /* Rotating amber gradient ring behind the photo */
  .founder-ring {
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    z-index: 0;
    background: conic-gradient(from 0deg, #F59E0B, #FCD34D, rgba(245,158,11,0.12), #F59E0B);
    filter: blur(2px);
    opacity: 0.6;
    animation: orb-spin 9s linear infinite;
  }
  @keyframes orb-spin { to { transform: rotate(360deg); } }

  /* Soft amber glow */
  .founder-photo-wrap::after {
    content: "";
    position: absolute;
    inset: -22%;
    border-radius: 50%;
    z-index: -1;
    background: radial-gradient(circle, rgba(245,158,11,0.22), transparent 62%);
    filter: blur(14px);
    animation: orb-pulse 4s ease-in-out infinite;
  }
  @keyframes orb-pulse { 0%,100% { opacity: 0.6; } 50% { opacity: 1; } }

  /* ── Credibility copy ─────────────────────────────────── */
  .founder-name { margin-bottom: 0.15rem; }
  .founder-bio {
    margin: 0.5rem 0 0;
    max-width: 32ch;
    font-size: 0.82rem;
    line-height: 1.62;
    font-style: italic;
    color: rgba(255,255,255,0.64);
  }
  .founder-meta {
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
    margin-top: 0.65rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.02em;
    color: rgba(255,255,255,0.52);
  }
  .founder-meta::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--green, #10B981);
    box-shadow: 0 0 8px var(--green, #10B981);
    flex-shrink: 0;
  }

  /* Stacked footer (≤900px): keep founder centred, a touch smaller */
  @media (max-width: 900px) {
    .footer-founder { --orb-size: 96px; margin-block: 0.5rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .founder-photo-wrap,
    .founder-ring,
    .founder-photo-wrap::after { animation: none !important; }
  }
</style>
