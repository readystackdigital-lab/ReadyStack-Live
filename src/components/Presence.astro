<section id="presence" class="section" aria-labelledby="presence-heading">
  <div class="container">
    <div class="section-head reveal">
      <div class="eyebrow">Online Presence</div>
      <h2 id="presence-heading" class="section-h2">
        Build trust online<br>
        <span class="text-amber">without adding more work to your day.</span>
      </h2>
      <p class="section-subline">A good website should help customers understand your services, trust your business and contact you easily. ReadyStack Digital connects the key pieces: website, domain, email, SEO setup, contact forms and monthly care.</p>
    </div>

    <div class="offer-grid">
      <div class="offer-card reveal">
        <div class="offer-kicker">Trust</div>
        <h3 class="svc-name">Look more professional</h3>
        <p class="svc-desc">A clean website and professional business email make your business look established, consistent and easier to trust.</p>
      </div>
      <div class="offer-card reveal reveal-delay-1">
        <div class="offer-kicker">Enquiries</div>
        <h3 class="svc-name">Make contact easy</h3>
        <p class="svc-desc">Contact forms, phone links, email buttons and WhatsApp CTAs make it easier for customers to reach you.</p>
      </div>
      <div class="offer-card reveal reveal-delay-2">
        <div class="offer-kicker">Visibility</div>
        <h3 class="svc-name">Help Google understand your site</h3>
        <p class="svc-desc">Basic SEO setup, sitemap, Search Console and clean page structure give your website a proper foundation.</p>
      </div>
    </div>
  </div>
</section>
