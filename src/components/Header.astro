---
const path = (Astro.url.pathname.replace(/\/+$/, "") || "/");
// Primary nav (desktop). The logo covers "Home".
const primaryNav = [
  { label: "Services", href: "/services" },
  { label: "Pricing", href: "/packages" },
  { label: "How It Works", href: "/how-it-works" },
  { label: "FAQs", href: "/faqs" },
  { label: "Contact", href: "/contact" },
  { label: "Social", href: "/social" },
  { label: "Blog", href: "/blog" },
];
const mobileNav = [
  { label: "Home", href: "/" },
  ...primaryNav,
];
const isActive = (href: string) =>
  href === "/" ? path === "/" : path === href || path.startsWith(href + "/");
---

<header id="site-header">
  <nav id="nav" role="navigation" aria-label="Primary navigation">
    <div class="nav-inner">

      <a href="/" class="nav-logo" aria-label="ReadyStack Digital home">
        <div class="logo-mark" aria-hidden="true">
          <img src="/assets/icons/readystack-icon.svg" alt="" width="32" height="32" />
        </div>
        <div class="logo-text">
          <span class="logo-adc">ReadyStack Digital</span>
          <span class="logo-full">for growing businesses</span>
        </div>
      </a>

      <ul class="nav-links" role="list">
        {primaryNav.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={["nav-link", { active: isActive(item.href) }]}
              aria-current={isActive(item.href) ? "page" : undefined}
            >{item.label}</a>
          </li>
        ))}
      </ul>

      <div class="nav-actions">
        <!-- Persistent primary CTA (desktop) -->
        <a href="/contact" class="btn btn-amber nav-cta">Get a Quote</a>

        <!-- Light / Dark mode toggle (animated switch, 21st.dev pattern) -->
        <button id="theme-toggle" class="theme-toggle" type="button" role="switch" aria-checked="true" aria-label="Toggle light and dark mode" title="Toggle light / dark mode">
          <span class="theme-toggle-track" aria-hidden="true">
            <span class="theme-toggle-thumb">
              <svg class="theme-ico theme-ico-moon" width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" fill="currentColor"/></svg>
              <svg class="theme-ico theme-ico-sun" width="13" height="13" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="4.2" fill="currentColor"/><g stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 2.5v2.2M12 19.3v2.2M4.6 4.6l1.6 1.6M17.8 17.8l1.6 1.6M2.5 12h2.2M19.3 12h2.2M4.6 19.4l1.6-1.6M17.8 6.2l1.6-1.6"/></g></svg>
            </span>
          </span>
        </button>

        <button type="button" class="nav-hamburger" id="nav-toggle"
          aria-label="Open navigation menu" aria-expanded="false" aria-controls="mobile-menu">
          <span></span><span></span><span></span>
        </button>
      </div>

    </div>

    <!-- Living scroll-progress indicator hugging the pill's lower edge -->
    <div class="nav-progress" aria-hidden="true">
      <span class="nav-progress-fill" id="nav-progress-fill"></span>
    </div>
  </nav>

  <div id="mobile-menu" class="mobile-menu" aria-hidden="true" role="dialog" aria-label="Mobile navigation">
    <div class="mobile-menu-inner">
      <nav aria-label="Mobile navigation links">
        <ul role="list">
          {mobileNav.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={["mobile-link", { active: isActive(item.href) }]}
                aria-current={isActive(item.href) ? "page" : undefined}
              >{item.label}</a>
            </li>
          ))}
        </ul>
      </nav>
      <a href="/contact" class="btn btn-amber btn-full">Get a Quote</a>
    </div>
  </div>
</header>

<!-- Nav scroll-progress — reads page scroll, paints the pill's underline fill -->
<script is:inline>
  (function initNavProgress() {
    const fill = document.getElementById('nav-progress-fill');
    if (!fill) return;

    let ticking = false;
    function update() {
      ticking = false;
      const doc = document.documentElement;
      const max = (doc.scrollHeight - doc.clientHeight) || 1;
      const pct = Math.min(1, Math.max(0, window.scrollY / max));
      fill.style.transform = 'scaleX(' + pct.toFixed(4) + ')';
    }
    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(update);
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
  })();
</script>

<!-- Light / Dark theme toggle -->
<script is:inline>
  (function initThemeToggle() {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    const root = document.documentElement;
    function sync() {
      const isDark = root.getAttribute('data-theme') !== 'light';
      btn.setAttribute('aria-checked', String(isDark));
    }
    sync();
    btn.addEventListener('click', function () {
      const next = root.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
      root.setAttribute('data-theme', next);
      try { localStorage.setItem('rsd-theme', next); } catch (e) {}
      sync();
    });
  })();
</script>

<style>
  /* ── Shimmer Button — adapted from MagicUI shimmer-button (21st.dev) ─── */
  .btn-shimmer {
    --shimmer-color: #F59E0B;
    --speed: 3s;
    --cut: 1.5px;
    position: relative;
    z-index: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border: 1.5px solid rgba(245, 158, 11, 0.22);
    border-radius: 100px;
    text-decoration: none;
    cursor: pointer;
    font-family: inherit;
    white-space: nowrap;
    transition: border-color 0.2s, transform 0.15s;
  }

  .btn-shimmer:hover {
    border-color: rgba(245, 158, 11, 0.55);
    transform: translateY(-1px);
  }

  .btn-shimmer:active {
    transform: translateY(0);
  }

  /* Rotating amber spark — sits behind the button content */
  .shimmer-spark-container {
    position: absolute;
    inset: 0;
    z-index: -1;
    overflow: visible;
    filter: blur(2px);
    container-type: inline-size;
  }

  .shimmer-spark {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    aspect-ratio: 1;
    animation: shimmer-slide var(--speed) ease-in-out infinite alternate;
  }

  .shimmer-spark-inner {
    position: absolute;
    inset: -100%;
    width: auto;
    animation: spin-around calc(var(--speed) * 2) infinite linear;
    background: conic-gradient(
      from calc(270deg - 45deg),
      transparent 0,
      var(--shimmer-color) 90deg,
      transparent 90deg
    );
  }

  /* Dark fill that masks the spark inside the border area */
  .shimmer-bg {
    position: absolute;
    inset: var(--cut);
    z-index: -1;
    border-radius: 100px;
    background: rgba(8, 12, 24, 0.97);
    transition: background 0.25s;
  }

  .btn-shimmer:hover .shimmer-bg {
    background: rgba(245, 158, 11, 0.07);
  }

  /* Visible label + icon */
  .shimmer-label {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: #F59E0B;
    padding: 0.4rem 0.9rem;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  @keyframes spin-around {
    0%       { transform: rotate(0deg); }
    15%, 35% { transform: rotate(90deg); }
    65%, 85% { transform: rotate(270deg); }
    100%     { transform: rotate(360deg); }
  }

  @keyframes shimmer-slide {
    to { transform: translate(calc(100cqw - 100%), 0); }
  }

  /* ── Mobile Book a Call button ─────────────────────────────────────── */
  .btn-book-mobile {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    border: 1.5px solid rgba(245, 158, 11, 0.3);
    color: #F59E0B;
    background: rgba(245, 158, 11, 0.05);
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 500;
    padding: 0.75rem 1rem;
    text-decoration: none;
    width: 100%;
    transition: background 0.2s, border-color 0.2s;
  }

  .btn-book-mobile:hover {
    background: rgba(245, 158, 11, 0.1);
    border-color: rgba(245, 158, 11, 0.55);
  }

  /* Keep amber styles even when .mobile-link applies */
  .btn-book-mobile.mobile-link {
    display: inline-flex;
    font-family: inherit;
    color: #F59E0B;
    border: 1.5px solid rgba(245, 158, 11, 0.3);
    border-bottom: 1.5px solid rgba(245, 158, 11, 0.3);
    background: rgba(245, 158, 11, 0.05);
  }

  .btn-book-mobile.mobile-link:hover {
    color: #fbbf24;
    padding-left: 1rem;
    background: rgba(245, 158, 11, 0.1);
  }

  /* ═══════════════════════════════════════════════════════════
     PREMIUM NAV LAYER — entrance · glass · logo · links · details
  ═══════════════════════════════════════════════════════════ */

  /* ── Nav entrance: drop + fade on load ─────────────────────── */
  @keyframes nav-drop-in {
    from { opacity: 0; transform: translateY(-18px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  #site-header :global(#nav) {
    animation: nav-drop-in .7s cubic-bezier(.16, 1, .3, 1) .1s both;
    /* Richer glass + soft elevation */
    box-shadow:
      0 8px 28px rgba(28, 28, 30, 0.12),
      0 2px 8px rgba(28, 28, 30, 0.06),
      0 1px 0 rgba(255, 255, 255, 0.55) inset;
    overflow: visible;
  }

  /* Deeper, more saturated glass once scrolled — amber kiss on the border */
  #site-header :global(#nav.nav-scrolled) {
    box-shadow:
      0 12px 38px rgba(28, 28, 30, 0.18),
      0 2px 10px rgba(245, 158, 11, 0.08),
      0 1px 0 rgba(255, 255, 255, 0.6) inset;
  }

  /* ── Living scroll-progress hugging the bar's lower edge ────── */
  .nav-progress {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 2px;
    border-radius: 2px;
    background: rgba(28, 28, 30, 0.06);
    overflow: hidden;
    pointer-events: none;
    opacity: 0;
    transition: opacity .35s ease;
  }
  #site-header :global(#nav.nav-scrolled) .nav-progress { opacity: 1; }

  .nav-progress-fill {
    display: block;
    height: 100%;
    width: 100%;
    transform: scaleX(0);
    transform-origin: left center;
    border-radius: inherit;
    background: linear-gradient(90deg, #F59E0B, #FCD34D);
    box-shadow: 0 0 8px rgba(245, 158, 11, 0.5);
    will-change: transform;
  }

  /* ── Logo mark — amber glow ring + hover micro-interaction ─── */
  .nav-logo { position: relative; }
  .nav-logo :global(.logo-mark) {
    position: relative;
    border-radius: 9px;
    transition: transform .35s cubic-bezier(.16, 1, .3, 1);
  }
  .nav-logo :global(.logo-mark)::after {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 11px;
    background: radial-gradient(circle at 50% 50%, rgba(245, 158, 11, 0.45), transparent 70%);
    opacity: 0;
    transition: opacity .35s ease;
    z-index: -1;
    pointer-events: none;
  }
  .nav-logo:hover :global(.logo-mark) {
    transform: scale(1.06) rotate(-3deg);
  }
  .nav-logo:hover :global(.logo-mark)::after { opacity: 1; }
  .nav-logo :global(.logo-adc) { transition: color .25s ease; }
  .nav-logo:hover :global(.logo-adc) { color: #B45309; }

  /* ── Nav links — soft pill on hover, refined active state ───── */
  #site-header :global(.nav-link) {
    position: relative;
    border-radius: 10px;
    transition: color .22s ease, background .22s ease;
  }
  #site-header :global(.nav-link)::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: rgba(28, 28, 30, 0.05);
    opacity: 0;
    transform: scale(.85);
    transition: opacity .22s ease, transform .22s cubic-bezier(.16, 1, .3, 1);
    z-index: -1;
  }
  #site-header :global(.nav-link:hover)::before {
    opacity: 1;
    transform: scale(1);
  }
  /* Active link: amber-tinted pill */
  #site-header :global(.nav-link.active)::before {
    opacity: 1;
    transform: scale(1);
    background: rgba(245, 158, 11, 0.12);
  }
  #site-header :global(.nav-link.active) {
    color: #B45309;
  }

  /* ── Status dot — double-pulse ping ring ───────────────────── */
  .nav-status { position: relative; }
  .nav-status :global(.status-dot) {
    position: relative;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--green);
    flex-shrink: 0;
  }
  .nav-status :global(.status-dot)::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: var(--green);
    animation: status-ping 2.4s cubic-bezier(0, 0, .2, 1) infinite;
  }
  @keyframes status-ping {
    0%   { transform: scale(1);   opacity: .7; }
    70%, 100% { transform: scale(2.6); opacity: 0; }
  }

  /* ── "Get a Quote" — amber gleam sweep ─────────────────────── */
  #site-header :global(.btn-amber) {
    position: relative;
    overflow: hidden;
  }
  #site-header :global(.btn-amber)::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(108deg, transparent 30%, rgba(255, 255, 255, 0.45) 50%, transparent 70%);
    background-size: 220% 100%;
    pointer-events: none;
    animation: nav-quote-gleam 4.5s ease-in-out 1.6s infinite;
  }
  @keyframes nav-quote-gleam {
    0%   { background-position: 180% center; opacity: 0; }
    14%  { opacity: 1; }
    30%  { opacity: 1; }
    44%  { background-position: -80% center; opacity: 0; }
    100% { background-position: -80% center; opacity: 0; }
  }

  /* ── Hamburger — amber on active/hover ─────────────────────── */
  #site-header :global(.nav-hamburger:hover span) { background: #B45309; }
  #site-header :global(.nav-hamburger.open span) { background: #F59E0B; }

  /* ── Reduced motion: silence the living details ────────────── */
  @media (prefers-reduced-motion: reduce) {
    #site-header :global(#nav) { animation: none !important; }
    .nav-status :global(.status-dot)::after { animation: none !important; }
    #site-header :global(.btn-amber)::after { animation: none !important; }
  }

  /* ── Mobile: progress line still hugs the bar's bottom edge ─── */
  @media (max-width: 768px) {
    .nav-progress { left: 0; right: 0; bottom: 0; }
  }

  /* ── Persistent desktop CTA ────────────────────────────────── */
  .nav-cta {
    padding: 0.55rem 1.15rem;
    min-height: 0;
    font-size: 0.875rem;
    border-radius: 999px;
    white-space: nowrap;
  }
  /* Hidden below the nav breakpoint — the mobile menu CTA takes over */
  @media (max-width: 900px) {
    #site-header .nav-cta { display: none; }
  }
</style>
