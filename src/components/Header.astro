---
---

<header id="site-header">
  <nav id="nav" role="navigation" aria-label="Primary navigation">
    <div class="nav-inner">

      <a href="#hero" class="nav-logo" aria-label="ReadyStack Digital home">
        <div class="logo-mark" aria-hidden="true">
          <img src="/assets/icons/readystack-icon.svg" alt="" width="32" height="32" />
        </div>
        <div class="logo-text">
          <span class="logo-adc">ReadyStack Digital</span>
          <span class="logo-full">for Australian SMBs</span>
        </div>
      </a>

      <ul class="nav-links" role="list">
        <li><a href="#hero"     class="nav-link" data-nav="hero">Home</a></li>
        <li><a href="#services" class="nav-link" data-nav="services">Services</a></li>
        <li><a href="#pricing"  class="nav-link" data-nav="pricing">Packages</a></li>
        <li><a href="#process"  class="nav-link" data-nav="process">How It Works</a></li>
        <li><a href="#faqs"     class="nav-link" data-nav="faqs">FAQs</a></li>
        <li><a href="#contact"  class="nav-link" data-nav="contact">Contact</a></li>
      </ul>

      <div class="nav-actions">
        <div class="nav-status" title="Australia-wide website support">
          <span class="status-dot" aria-hidden="true"></span>
          <span class="status-text">Australia-wide</span>
        </div>
        <a href="#contact" class="btn btn-amber btn-sm">Get a Quote</a>
        <button type="button" class="nav-hamburger" id="nav-toggle"
          aria-label="Open navigation menu" aria-expanded="false" aria-controls="mobile-menu">
          <span></span><span></span><span></span>
        </button>
      </div>

    </div>
  </nav>

  <div id="mobile-menu" class="mobile-menu" aria-hidden="true" role="dialog" aria-label="Mobile navigation">
    <div class="mobile-menu-inner">
      <nav aria-label="Mobile navigation links">
        <ul role="list">
          <li><a href="#hero"     class="mobile-link">Home</a></li>
          <li><a href="#services" class="mobile-link">Services</a></li>
          <li><a href="#pricing"  class="mobile-link">Packages</a></li>
          <li><a href="#process"  class="mobile-link">How It Works</a></li>
          <li><a href="#faqs"     class="mobile-link">FAQs</a></li>
          <li><a href="#contact"  class="mobile-link">Contact</a></li>
        </ul>
      </nav>
      <a href="#contact" class="btn btn-amber btn-full">Get a Website Quote</a>
    </div>
  </div>
</header>
