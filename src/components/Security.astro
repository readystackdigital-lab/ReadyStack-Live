---
---

<section id="security" class="section" aria-labelledby="security-heading">
  <div class="container">

    <div class="compliance-grid">

      <div class="compliance-copy reveal">
        <div class="eyebrow">Secure Online Presence</div>
        <h2 id="security-heading" class="section-h2">
          Secure website, email and domain foundations<br>
          <span class="text-amber">handled properly from the start.</span>
        </h2>
        <p class="body-copy">
          Security does not need to be complicated for most local business websites, but the basics must be done properly. ReadyStack Digital keeps your setup lean, secure and easier to maintain by using HTTPS, secure hosting, DNS checks, form testing, email authentication records and a static-first website approach where suitable.
        </p>
        <p class="body-copy">
          Your business gets a professional online presence that customers can trust, while you avoid unnecessary plugins, risky admin logins and confusing technical maintenance.
        </p>
        <div class="compliance-ctas">
          <a href="#contact" class="btn btn-amber magnetic"><span>Plan My Secure Setup</span></a>
          <a href="#pricing" class="btn btn-ghost"><span>View Care Plans</span></a>
        </div>
      </div>

      <div class="compliance-dashboard reveal reveal-delay-1" role="img" aria-label="ReadyStack Digital secure website care dashboard preview">
        <div class="dashboard-frame">

          <div class="dash-topbar">
            <div class="dash-brand">
              <div class="dash-brand-mark" aria-hidden="true">ReadyStack Digital</div>
              <span class="dash-brand-label">Website Care</span>
              <div class="dash-live-badge">
                <span class="live-dot" aria-hidden="true"></span>
                MANAGED
              </div>
            </div>
            <div class="dash-topbar-right" aria-hidden="true">
              <span class="dash-clock" id="dash-clock">--:--:--</span>
            </div>
          </div>

          <div class="dash-body">

            <div class="dash-panel dash-score-panel">
              <div class="panel-topbar">
                <span class="panel-title">Secure Setup</span>
                <span class="panel-badge panel-badge-green">Baseline</span>
              </div>
              <div class="score-placeholder">
                <span>HTTPS enabled</span>
                <small>Secure site connection</small>
              </div>
              <div class="score-placeholder">
                <span>Email records ready</span>
                <small>SPF, DKIM and DMARC support</small>
              </div>
            </div>

            <div class="dash-panel dash-operate-panel">
              <div class="panel-topbar">
                <span class="panel-title">Online Presence</span>
                <span class="panel-badge panel-badge-green">Checked</span>
              </div>
              <div class="operate-stack-mini">
                <div class="operate-mini-item">
                  <span class="operate-dot"></span>
                  <div>
                    <strong>Website</strong>
                    <span>Fast static setup where suitable</span>
                  </div>
                </div>
                <div class="operate-mini-item">
                  <span class="operate-dot"></span>
                  <div>
                    <strong>Domain</strong>
                    <span>DNS records reviewed</span>
                  </div>
                </div>
                <div class="operate-mini-item">
                  <span class="operate-dot"></span>
                  <div>
                    <strong>Email</strong>
                    <span>Business email option supported</span>
                  </div>
                </div>
                <div class="operate-mini-item">
                  <span class="operate-dot"></span>
                  <div>
                    <strong>Forms</strong>
                    <span>Enquiry delivery tested</span>
                  </div>
                </div>
              </div>
            </div>

          </div>

          <div class="dash-metrics-strip">

            <div class="dash-metric">
              <div class="metric-icon-wrap metric-green" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M7 1.5L2 4v3.2c0 3 2.1 5.3 5 6.3 2.9-1 5-3.3 5-6.3V4L7 1.5z" stroke="#10B981" stroke-width="1.2" fill="none"/>
                  <path d="M4.7 7.1l1.5 1.5 3.1-3.1" stroke="#10B981" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
              </div>
              <div class="metric-body">
                <div class="metric-val">HTTPS</div>
                <div class="metric-lbl">Secure site</div>
              </div>
            </div>

            <div class="dash-metric">
              <div class="metric-icon-wrap metric-amber" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <rect x="1.8" y="3" width="10.4" height="8" rx="1.6" stroke="#F59E0B" stroke-width="1.1"/>
                  <path d="M2.4 4l4.6 3.5L11.6 4" stroke="#F59E0B" stroke-width="1.1" stroke-linecap="round"/>
                </svg>
              </div>
              <div class="metric-body">
                <div class="metric-val">SPF DKIM</div>
                <div class="metric-lbl">Email trust</div>
              </div>
            </div>

            <div class="dash-metric">
              <div class="metric-icon-wrap metric-blue" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <circle cx="7" cy="7" r="5.5" stroke="#3B82F6" stroke-width="1.2"/>
                  <path d="M2 7h10M7 1.5c1.4 1.4 2 3.2 2 5.5s-.6 4.1-2 5.5M7 1.5c-1.4 1.4-2 3.2-2 5.5s.6 4.1 2 5.5" stroke="#3B82F6" stroke-width=".9"/>
                </svg>
              </div>
              <div class="metric-body">
                <div class="metric-val">DNS</div>
                <div class="metric-lbl">Domain checked</div>
              </div>
            </div>

            <div class="dash-metric">
              <div class="metric-icon-wrap metric-purple" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M2.2 3.5h9.6v7H4.5L2.2 12V3.5z" stroke="#8B5CF6" stroke-width="1.1" stroke-linejoin="round"/>
                  <path d="M4.2 6h5.6M4.2 8h3.4" stroke="#8B5CF6" stroke-width="1.1" stroke-linecap="round"/>
                </svg>
              </div>
              <div class="metric-body">
                <div class="metric-val">Forms</div>
                <div class="metric-lbl">Enquiries tested</div>
              </div>
            </div>

          </div>

        </div>

        <div class="dashboard-glow" aria-hidden="true"></div>
        <div class="dashboard-reflection" aria-hidden="true"></div>
      </div>

    </div>

    <div class="offer-grid reveal">
      <div class="offer-card">
        <div class="offer-kicker">Website Security</div>
        <h3 class="svc-name">SSL and HTTPS</h3>
        <p class="svc-desc">Your website is launched with a secure connection so visitors can access it through HTTPS.</p>
      </div>
      <div class="offer-card">
        <div class="offer-kicker">Email Trust</div>
        <h3 class="svc-name">SPF, DKIM and DMARC</h3>
        <p class="svc-desc">Professional business email can be configured with the records that help protect your domain identity.</p>
      </div>
      <div class="offer-card">
        <div class="offer-kicker">Lean Setup</div>
        <h3 class="svc-name">Fewer moving parts</h3>
        <p class="svc-desc">Where suitable, we avoid unnecessary plugins, dashboards and login systems that add maintenance risk.</p>
      </div>
    </div>

  </div>
</section>
