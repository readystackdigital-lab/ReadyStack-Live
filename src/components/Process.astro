---
---

<section id="process" class="section section-dark" aria-labelledby="process-heading">
  <div class="container">

    <div class="section-head reveal">
      <div class="eyebrow eyebrow-light">How It Works</div>
      <h2 id="process-heading" class="section-h2 section-h2-light">
        How ReadyStack Digital gets<br>
        <span class="text-amber">your website live</span><br>
        and keeps it managed.
      </h2>
    </div>

    <div class="process-wrap">
      <div class="process-connector" aria-hidden="true">
        <div class="connector-fill" id="connector-fill"></div>
      </div>

      <div class="process-steps">

        <div class="process-step reveal" data-step="1">
          <div class="step-node" aria-hidden="true"><span class="step-num">01</span></div>
          <div class="step-body">
            <div class="step-tag">Step 1</div>
            <h3 class="step-title">Tell Us About Your Business</h3>
            <p class="step-desc">We collect your business details, services, branding, contact information, domain needs, email requirements, SEO goals, and website priorities.</p>
            <div class="step-outcome">Intake brief complete</div>
          </div>
        </div>

        <div class="process-step reveal reveal-delay-1" data-step="2">
          <div class="step-node" aria-hidden="true"><span class="step-num">02</span></div>
          <div class="step-body">
            <div class="step-tag">Step 2</div>
            <h3 class="step-title">We Plan the Website</h3>
            <p class="step-desc">We map the page structure, key sections, calls to action, contact flow, domain setup, business email option, SEO basics, and monthly care requirements.</p>
            <div class="step-outcome">Sitemap &amp; scope confirmed</div>
          </div>
        </div>

        <div class="process-step reveal reveal-delay-2" data-step="3">
          <div class="step-node" aria-hidden="true"><span class="step-num">03</span></div>
          <div class="step-body">
            <div class="step-tag">Step 3</div>
            <h3 class="step-title">We Build and Configure</h3>
            <p class="step-desc">We design the website, connect hosting, configure forms, prepare SEO basics, set up secure HTTPS, review DNS, and support professional business email setup if selected.</p>
            <div class="step-outcome">Website ready to review</div>
          </div>
        </div>

        <div class="process-step reveal reveal-delay-3" data-step="4">
          <div class="step-node" aria-hidden="true"><span class="step-num">04</span></div>
          <div class="step-body">
            <div class="step-tag">Step 4</div>
            <h3 class="step-title">You Review</h3>
            <p class="step-desc">You check the website before launch and request final adjustments. We keep the process practical, focused, and aligned with your business goals.</p>
            <div class="step-outcome">Launch approved</div>
          </div>
        </div>

        <div class="process-step reveal reveal-delay-4" data-step="5">
          <div class="step-node" aria-hidden="true"><span class="step-num">05</span></div>
          <div class="step-body">
            <div class="step-tag">Ongoing</div>
            <h3 class="step-title">We Launch, Manage and Keep You Visible</h3>
            <p class="step-desc">Your website goes live, then monthly care keeps the technical side handled with hosting, domain checks, SSL monitoring, form testing, basic SEO checks, and small updates, plus optional blog and social media content to keep your business active online.</p>
            <div class="step-outcome">Care &amp; content active</div>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>
