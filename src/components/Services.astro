---
---

<section id="services" class="section section-tinted" aria-labelledby="services-heading">
  <div class="container">

    <div class="section-head reveal">
      <div class="eyebrow">What We Do</div>
      <h2 id="services-heading" class="section-h2">
        Everything your local business needs<br><span class="text-amber">to look professional online.</span>
      </h2>
      <p class="section-subline">ReadyStack Digital gives local businesses one simple place to manage their online presence: website, domain, hosting, email, SEO setup, contact forms, monthly care, and branded social media and blog content.</p>
    </div>

    <div class="svc-filter-wrap" role="group" aria-label="Filter services by category">
      <button class="svc-filter-btn active" data-filter="all">All Services</button>
      <button class="svc-filter-btn" data-filter="build">Website Build</button>
      <button class="svc-filter-btn" data-filter="infra">Domain &amp; Email</button>
      <button class="svc-filter-btn" data-filter="care">Monthly Care</button>
      <button class="svc-filter-btn" data-filter="social">Social &amp; Content</button>
      <button class="svc-filter-btn" data-filter="ai">AI Agent</button>
    </div>

    <div class="services-grid">

      <article class="svc-card reveal" data-cat="build" aria-labelledby="svc-website-build">
        <div class="svc-top">
          <div class="svc-icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 26 26" fill="none">
              <rect x="3" y="5" width="20" height="14" rx="3" stroke="#F59E0B" stroke-width="1.4" fill="none"/>
              <path d="M3 9h20M8 22h10M13 19v3" stroke="#F59E0B" stroke-width="1.4" stroke-linecap="round"/>
            </svg>
          </div>
          <span class="svc-tier">Website Build</span>
        </div>
        <h3 id="svc-website-build" class="svc-name">Website Design and Build</h3>
        <p class="svc-desc">Fast, mobile-friendly websites designed to help local businesses explain their services, build trust, and generate enquiries.</p>
        <div class="svc-tags"><span>Landing Page</span><span>Business Website</span><span>Mobile Friendly</span><span>Fast Loading</span></div>
        <div class="svc-metric"><span class="svc-metric-num">$799+</span><span class="svc-metric-lbl">website builds from</span></div>
        <div class="svc-actions"><a href="/contact" class="btn btn-outline btn-full">Start a website build</a></div>
      </article>

      <article class="svc-card reveal reveal-delay-1" data-cat="infra" aria-labelledby="svc-domain-hosting">
        <div class="svc-top">
          <div class="svc-icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 26 26" fill="none">
              <circle cx="13" cy="13" r="10" stroke="#F59E0B" stroke-width="1.4"/>
              <ellipse cx="13" cy="13" rx="4.5" ry="10" stroke="#F59E0B" stroke-width="1.4"/>
              <path d="M3 13h20" stroke="#F59E0B" stroke-width="1.4"/>
            </svg>
          </div>
          <span class="svc-tier">Domain and Hosting</span>
        </div>
        <h3 id="svc-domain-hosting" class="svc-name">Domain and Hosting Setup</h3>
        <p class="svc-desc">We help register or connect your domain, configure DNS, connect hosting, set up SSL, and prepare your website for launch.</p>
        <div class="svc-tags"><span>Domain</span><span>DNS</span><span>Hosting</span><span>SSL</span></div>
        <div class="svc-metric"><span class="svc-metric-num">Live</span><span class="svc-metric-lbl">connected and checked</span></div>
        <div class="svc-actions"><a href="/packages" class="btn btn-outline btn-full">View care options</a></div>
      </article>

      <article class="svc-card svc-card-hot reveal reveal-delay-2" data-cat="infra" aria-labelledby="svc-business-email">
        <div class="svc-top">
          <div class="svc-icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 26 26" fill="none">
              <rect x="3" y="6" width="20" height="14" rx="3" stroke="#F59E0B" stroke-width="1.4" fill="none"/>
              <path d="M4 8l9 7 9-7" stroke="#F59E0B" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="20" cy="6" r="3" fill="rgba(245,158,11,.14)" stroke="#F59E0B" stroke-width="1.2"/>
            </svg>
          </div>
          <span class="svc-tier svc-tier-hot">Optional Add-on</span>
        </div>
        <h3 id="svc-business-email" class="svc-name">Professional Business Email</h3>
        <p class="svc-desc">Add professional email such as info@yourdomain.com with support for MX, SPF, DKIM, and DMARC records.</p>
        <div class="svc-tags"><span>Business Email</span><span>MX</span><span>SPF</span><span>DKIM</span><span>DMARC</span></div>
        <div class="svc-metric"><span class="svc-metric-num">@</span><span class="svc-metric-lbl">domain-based identity</span></div>
        <div class="svc-actions"><a href="/contact" class="btn btn-outline btn-full">Ask about email</a></div>
      </article>

      <article class="svc-card reveal" data-cat="build" aria-labelledby="svc-contact-forms">
        <div class="svc-top">
          <div class="svc-icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 26 26" fill="none">
              <path d="M5 6h16v10H9l-4 4V6z" stroke="#F59E0B" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M9 10h8M9 13h5" stroke="#F59E0B" stroke-width="1.4" stroke-linecap="round"/>
            </svg>
          </div>
          <span class="svc-tier">Lead Enquiries</span>
        </div>
        <h3 id="svc-contact-forms" class="svc-name">Contact Forms and WhatsApp Enquiries</h3>
        <p class="svc-desc">Make it easy for customers to contact you through enquiry forms, call buttons, email links, and WhatsApp messaging.</p>
        <div class="svc-tags"><span>Forms</span><span>WhatsApp</span><span>Call Button</span><span>Email Links</span></div>
        <div class="svc-metric"><span class="svc-metric-num">24/7</span><span class="svc-metric-lbl">always available online</span></div>
        <div class="svc-actions"><a href="/contact" class="btn btn-outline btn-full">Plan enquiry flow</a></div>
      </article>

      <article class="svc-card reveal reveal-delay-1" data-cat="build" aria-labelledby="svc-seo-setup">
        <div class="svc-top">
          <div class="svc-icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 26 26" fill="none">
              <path d="M4 19V7a2 2 0 012-2h14a2 2 0 012 2v12" stroke="#F59E0B" stroke-width="1.4" stroke-linecap="round"/>
              <path d="M7 15l3-3 3 2 5-6" stroke="#F59E0B" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M3 21h20" stroke="#F59E0B" stroke-width="1.4" stroke-linecap="round"/>
            </svg>
          </div>
          <span class="svc-tier svc-tier-premium">Included</span>
        </div>
        <h3 id="svc-seo-setup" class="svc-name">SEO Website Setup</h3>
        <p class="svc-desc">Every website includes SEO basics such as page titles, meta descriptions, heading structure, sitemap, image alt text, and Google Search Console setup.</p>
        <div class="svc-tags"><span>SEO Basics</span><span>Sitemap</span><span>Search Console</span><span>Local Signals</span></div>
        <div class="svc-metric"><span class="svc-metric-num">SEO</span><span class="svc-metric-lbl">foundations included</span></div>
        <div class="svc-actions"><a href="/packages" class="btn btn-outline btn-full">See what is included</a></div>
      </article>

      <article class="svc-card reveal reveal-delay-2" data-cat="care" aria-labelledby="svc-secure-care">
        <div class="svc-top">
          <div class="svc-icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 26 26" fill="none">
              <path d="M13 2L3 7v6C3 18.75 7.5 24 13 25.5 18.5 24 23 18.75 23 13V7L13 2z" stroke="#F59E0B" stroke-width="1.4" fill="rgba(245,158,11,.08)"/>
              <path d="M9.5 13l2.5 2.5 4.5-4.5" stroke="#F59E0B" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <span class="svc-tier svc-tier-premium">Monthly Care</span>
        </div>
        <h3 id="svc-secure-care" class="svc-name">Secure Monthly Website Care</h3>
        <p class="svc-desc">Keep your website, domain, forms, SSL, DNS, and basic SEO checks managed every month with a lean setup that avoids unnecessary plugin and login risks.</p>
        <div class="svc-tags"><span>HTTPS</span><span>SSL Checks</span><span>DNS Checks</span><span>Form Testing</span></div>
        <div class="svc-metric"><span class="svc-metric-num">$99+</span><span class="svc-metric-lbl">monthly care from</span></div>
        <div class="svc-actions"><a href="/packages" class="btn btn-outline btn-full">View monthly care</a></div>
      </article>

      <article class="svc-card reveal reveal-delay-1" data-cat="social" aria-labelledby="svc-social-content">
        <div class="svc-top">
          <div class="svc-icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 26 26" fill="none">
              <rect x="3.5" y="3.5" width="19" height="19" rx="5" stroke="#F59E0B" stroke-width="1.4" fill="none"/>
              <circle cx="13" cy="13" r="4.2" stroke="#F59E0B" stroke-width="1.4" fill="none"/>
              <circle cx="18.2" cy="7.8" r="1.3" fill="#F59E0B"/>
            </svg>
          </div>
          <span class="svc-tier svc-tier-hot">New</span>
        </div>
        <h3 id="svc-social-content" class="svc-name">Social Media &amp; Content</h3>
        <p class="svc-desc">Consistent, branded content for Instagram, Facebook, TikTok, LinkedIn, and blog posts, designed to keep your business visible and professional online.</p>
        <div class="svc-tags"><span>Instagram</span><span>Facebook</span><span>TikTok</span><span>LinkedIn</span><span>Blog Posts</span></div>
        <div class="svc-metric"><span class="svc-metric-num">+Content</span><span class="svc-metric-lbl">aligned with your website</span></div>
        <div class="svc-actions"><a href="/social" class="btn btn-outline btn-full">Explore social media support</a></div>
      </article>

      <article class="svc-card svc-card-hot reveal reveal-delay-2" data-cat="ai" aria-labelledby="svc-ai-agent">
        <div class="svc-top">
          <div class="svc-icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 26 26" fill="none">
              <rect x="4" y="6" width="18" height="13" rx="4" stroke="#F59E0B" stroke-width="1.4" fill="none"/>
              <path d="M9 19l-2 3 5-3" stroke="#F59E0B" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="10" cy="12.5" r="1.3" fill="#F59E0B"/>
              <circle cx="16" cy="12.5" r="1.3" fill="#F59E0B"/>
              <path d="M13 3v3M11.4 4.2l3.2 1.6M14.6 4.2l-3.2 1.6" stroke="#F59E0B" stroke-width="1.2" stroke-linecap="round"/>
            </svg>
          </div>
          <span class="svc-tier svc-tier-hot">New</span>
        </div>
        <h3 id="svc-ai-agent" class="svc-name">AI Agent &amp; Reception</h3>
        <p class="svc-desc">A 24/7 AI receptionist on your website that answers customer questions instantly, captures leads, and books calls, trained on your business.</p>
        <div class="svc-tags"><span>24/7 Replies</span><span>Lead Capture</span><span>Booking</span><span>Trained on You</span></div>
        <div class="svc-metric"><span class="svc-metric-num">$1,499+</span><span class="svc-metric-lbl">AI setup from · $149/mo</span></div>
        <div class="svc-actions"><a href="/packages" class="btn btn-outline btn-full">Add an AI agent</a></div>
      </article>

    </div>
    <div class="service-index-cta reveal">
      <a href="/services" class="btn btn-amber btn-lg">Explore All Services</a>
      <a href="/packages" class="btn btn-ghost btn-lg">View Packages</a>
    </div>
  </div>
</section>
