---
// SEOHead.astro
// Import and drop inside <head> in BaseLayout.astro:
//   <SEOHead />
// Optional per-page overrides:
//   <SEOHead title="..." description="..." path="/" />

interface Props {
  title?: string;
  description?: string;
  path?: string;
  ogImage?: string;
}

const {
  title = "Secure Digital Foundations for Australian Small Businesses | ReadyStack Digital",
  description = "ReadyStack Digital builds secure digital foundations for Australian SMBs — website, Microsoft 365, Essential Eight alignment and email security, built and managed properly. Sydney-based, Australia-wide.",
  path = "/",
  ogImage = "/assets/images/og-readystack.png",
} = Astro.props;

const siteUrl = "https://readystackdigital.com";
const fullUrl = `${siteUrl}${path}`;
const fullOgImage = ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`;
---

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="keywords" content="secure digital foundations Australia, website design Sydney, Microsoft 365 small business Australia, Essential Eight SMB, email security SPF DKIM DMARC, small business website Australia, monthly managed care, ACSC Essential Eight, ReadyStack Digital" />
<meta name="author" content="ReadyStack Digital" />
<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
<meta name="googlebot" content="index, follow" />
<meta name="geo.region" content="AU-NSW" />
<meta name="geo.placename" content="Sydney" />
<meta name="geo.position" content="-33.8688;151.2093" />
<meta name="ICBM" content="-33.8688, 151.2093" />

<!-- Canonical -->
<link rel="canonical" href={fullUrl} />

<!-- Viewport (also belongs in BaseLayout, included here defensively) -->
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content="ReadyStack Digital" />
<meta property="og:url" content={fullUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={fullOgImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content="en_AU" />

<!-- Twitter / X -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={fullUrl} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullOgImage} />

<!-- Theme -->
<meta name="theme-color" content="#0a0a0a" />
<meta name="color-scheme" content="dark light" />

<!-- Sitemap reference for crawlers (also exposed via robots.txt) -->
<link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap.xml" />
