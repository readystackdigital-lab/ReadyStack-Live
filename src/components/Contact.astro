---
---

<section id="contact" class="section section-dark" aria-labelledby="contact-heading">
  <div class="container">

    <div class="contact-grid">
      <div class="contact-copy reveal">
        <div class="eyebrow eyebrow-dark">Contact</div>
        <h2 id="contact-heading" class="section-h2 section-h2-light">
          Ready to build a stronger online presence?
        </h2>
        <p class="section-subline section-subline-light">
          Tell us about your business and we will recommend the simplest setup for your website, domain, email, SEO and monthly care.
        </p>

        <div class="contact-info">
          <div class="contact-row">
            <div class="contact-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 16s6-4.5 6-9A6 6 0 1 0 3 7c0 4.5 6 9 6 9z" stroke="#F59E0B" stroke-width="1.3" fill="none"/><circle cx="9" cy="7" r="2" stroke="#F59E0B" stroke-width="1.3"/></svg>
            </div>
            <div>
              <div class="contact-label">Location</div>
              <div class="contact-val">Australia-wide website support for local businesses</div>
            </div>
          </div>
          <div class="contact-row">
            <div class="contact-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><rect x="2" y="4" width="14" height="10" rx="2" stroke="#F59E0B" stroke-width="1.3" fill="none"/><path d="M2 5l7 5 7-5" stroke="#F59E0B" stroke-width="1.3" stroke-linecap="round"/></svg>
            </div>
            <div>
              <div class="contact-label">Email</div>
              <div class="contact-val"><a href="mailto:hello@readystackdigital.com">hello@readystackdigital.com</a></div>
            </div>
          </div>
          <div class="contact-row">
            <div class="contact-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="7" stroke="#F59E0B" stroke-width="1.3" fill="none"/><path d="M9 5.5v3.75l2.25 2.25" stroke="#F59E0B" stroke-width="1.3" stroke-linecap="round"/></svg>
            </div>
            <div>
              <div class="contact-label">Response</div>
              <div class="contact-val">
                We respond within 1 business day
                <span class="contact-note">Active care clients receive ongoing website checks.</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="contact-form-wrap reveal reveal-delay-1">

        <div class="form-progress" aria-hidden="true">
          <div class="form-progress-step active" data-step="1">
            <div class="form-progress-dot">1</div>
            <span class="form-progress-label">About You</span>
          </div>
          <div class="form-progress-connector" data-after="1"></div>
          <div class="form-progress-step" data-step="2">
            <div class="form-progress-dot">2</div>
            <span class="form-progress-label">Your Business</span>
          </div>
          <div class="form-progress-connector" data-after="2"></div>
          <div class="form-progress-step" data-step="3">
            <div class="form-progress-dot">3</div>
            <span class="form-progress-label">Your Needs</span>
          </div>
        </div>

        <form id="contact-form" class="contact-form" action="https://api.web3forms.com/submit" method="post" novalidate aria-label="ReadyStack Digital enquiry form">
          <input type="hidden" name="access_key" value="44f5ac5c-31c8-4019-914b-8426212d137a" />
          <input type="hidden" name="subject" value="New enquiry from ReadyStack Digital website" />
          <input type="hidden" name="from_name" value="ReadyStack Digital Website" />
          <input type="checkbox" name="botcheck" style="display: none;" />

          <!-- Step 1: About You -->
          <div class="form-step active" data-step="1">
            <div class="form-row-2">
              <div class="form-group">
                <label for="first-name">First Name</label>
                <input type="text" id="first-name" name="firstName" required autocomplete="given-name" placeholder="Monip" />
              </div>
              <div class="form-group">
                <label for="last-name">Last Name</label>
                <input type="text" id="last-name" name="lastName" required autocomplete="family-name" placeholder="Last Name" />
              </div>
            </div>
            <div class="form-row-2">
              <div class="form-group">
                <label for="email">Business Email</label>
                <input type="email" id="email" name="email" required autocomplete="email" placeholder="you@yourbusiness.com.au" />
              </div>
              <div class="form-group">
                <label for="phone">Phone</label>
                <input type="tel" id="phone" name="phone" autocomplete="tel" placeholder="0400 000 000" />
              </div>
            </div>
            <div class="form-step-nav">
              <button type="button" class="btn btn-amber btn-full form-next" data-next="2">
                Next: Your Business
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
            </div>
          </div>

          <!-- Step 2: Your Business -->
          <div class="form-step" data-step="2">
            <div class="form-group">
              <label for="business">Business Name</label>
              <input type="text" id="business" name="businessName" required autocomplete="organization" placeholder="Your Business Pty Ltd" />
            </div>
            <div class="form-group">
              <label for="website">Current Website, if any</label>
              <input type="url" id="website" name="website" autocomplete="url" placeholder="https://yourbusiness.com.au" />
            </div>
            <div class="form-group">
              <label for="interest">What service are you interested in?</label>
              <select id="interest" name="interest">
                <option value="">Select a service</option>
                <option value="landing-page">Landing Page Website</option>
                <option value="business-website">Business Website</option>
                <option value="redesign">Website Redesign</option>
                <option value="domain-hosting">Domain and Hosting Setup</option>
                <option value="business-email">Professional Business Email</option>
                <option value="monthly-care">Monthly Website Care</option>
                <option value="blog-support">Blog Support</option>
                <option value="not-sure">Not Sure Yet</option>
              </select>
            </div>
            <div class="form-step-nav">
              <button type="button" class="btn btn-ghost form-back" data-back="1">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M11 7H3M7 3L3 7l4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Back
              </button>
              <button type="button" class="btn btn-amber form-next form-nav-primary" data-next="3">
                Next: Your Needs
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
            </div>
          </div>

          <!-- Step 3: Your Needs -->
          <div class="form-step" data-step="3">
            <div class="form-row-2">
              <div class="form-group">
                <label for="domain-owned">Do you already own a domain?</label>
                <select id="domain-owned" name="domainOwned">
                  <option value="">Select an option</option>
                  <option value="yes">Yes</option>
                  <option value="no">No</option>
                  <option value="not-sure">Not sure</option>
                </select>
              </div>
              <div class="form-group">
                <label for="email-needed">Need business email?</label>
                <select id="email-needed" name="emailNeeded">
                  <option value="">Select an option</option>
                  <option value="yes">Yes</option>
                  <option value="no">No</option>
                  <option value="not-sure">Not sure</option>
                </select>
              </div>
            </div>
            <div class="form-group">
              <label for="message">Tell us about your business</label>
              <textarea id="message" name="message" rows="4" placeholder="What do you do, who do you serve, and what do you need help with?"></textarea>
            </div>
            <div class="h-captcha" data-captcha="true"></div>
            <div class="form-step-nav">
              <button type="button" class="btn btn-ghost form-back" data-back="2">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M11 7H3M7 3L3 7l4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Back
              </button>
              <button type="submit" class="btn btn-amber form-nav-primary" id="form-submit">
                <span class="btn-label">Send Enquiry</span>
                <span class="btn-spinner" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none" class="spinning">
                    <circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="2" stroke-dasharray="22 22" stroke-linecap="round"/>
                  </svg>
                </span>
              </button>
            </div>
            <p class="form-note">Australia-wide website support for local businesses. We respond within 1 business day.</p>
          </div>

        </form>

        <div id="form-success" class="form-success" hidden aria-live="polite" role="status">
          <div class="success-icon" aria-hidden="true">
            <svg width="44" height="44" viewBox="0 0 44 44" fill="none">
              <circle cx="22" cy="22" r="20" stroke="#10B981" stroke-width="2"/>
              <path d="M13 22l7 7 11-13" stroke="#10B981" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3>Enquiry received.</h3>
          <p>We will review your details and respond within 1 business day.</p>
        </div>

      </div>
    </div>
  </div>
</section>
