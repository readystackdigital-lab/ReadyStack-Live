<style>
  /* ── Card wrapper ── */
  .contact-tab-container {
    display: flex;
    flex-direction: column;
    box-shadow: 0 24px 70px rgba(0, 0, 0, .18);
    border-radius: var(--radius-lg, 16px);
    overflow: hidden;
  }

  /* ── Tab bar ── */
  .contact-tabs {
    display: flex;
    background: rgba(255, 255, 255, 0.03);
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    padding: 0.5rem 0.5rem 0;
    gap: 0.25rem;
  }

  .contact-tab {
    background: transparent;
    border: none;
    border-radius: 8px 8px 0 0;
    color: rgba(255, 255, 255, 0.38);
    font-family: inherit;
    font-size: 0.8125rem;
    font-weight: 500;
    padding: 0.6rem 1.1rem;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    transition: color 0.18s, background 0.18s;
    letter-spacing: -0.01em;
    position: relative;
  }

  .contact-tab::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 2px;
    background: transparent;
    border-radius: 2px 2px 0 0;
    transition: background 0.18s;
  }

  .contact-tab:hover {
    color: rgba(255, 255, 255, 0.65);
    background: rgba(255, 255, 255, 0.04);
  }

  .contact-tab--active {
    color: #F59E0B;
    background: rgba(245, 158, 11, 0.08);
  }

  .contact-tab--active::after {
    background: #F59E0B;
  }

  /* ── Panels ── */
  .contact-panel {
    animation: panel-in 0.22s ease;
  }

  .contact-panel[hidden] {
    display: none;
  }

  @keyframes panel-in {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Booking panel ── */
  .cal-header {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    padding: 1.5rem 1.75rem 0;
  }

  .cal-header-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: rgba(245, 158, 11, 0.12);
    border: 1px solid rgba(245, 158, 11, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .cal-header-title {
    font-family: var(--font-display, inherit);
    font-size: 0.9375rem;
    font-weight: 600;
    color: #f1f5f9;
    margin: 0 0 0.2rem;
    line-height: 1.3;
  }

  .cal-header-sub {
    font-size: 0.8125rem;
    color: #475569;
    margin: 0;
    line-height: 1.5;
  }

  /* ── iframe + skeleton ── */
  .cal-wrap {
    padding: 1rem 0.75rem 1.25rem;
    position: relative;
  }

  .cal-skeleton {
    position: absolute;
    inset: 1rem 0.75rem 1.25rem;
    border-radius: 8px;
    overflow: hidden;
    background: rgba(255,255,255,0.03);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .cal-skel-row {
    height: 14px;
    border-radius: 6px;
    background: linear-gradient(90deg,
      rgba(255,255,255,0.05) 25%,
      rgba(255,255,255,0.1) 50%,
      rgba(255,255,255,0.05) 75%);
    background-size: 200% 100%;
    animation: shimmer 1.6s infinite;
  }
  .cal-skel-row--wide  { width: 70%; }
  .cal-skel-row--med   { width: 50%; }
  .cal-skel-row--short { width: 35%; }
  .cal-skel-block {
    height: 80px;
    border-radius: 6px;
    margin-top: 0.5rem;
    background: linear-gradient(90deg,
      rgba(255,255,255,0.04) 25%,
      rgba(255,255,255,0.08) 50%,
      rgba(255,255,255,0.04) 75%);
    background-size: 200% 100%;
    animation: shimmer 1.6s infinite 0.2s;
  }

  @keyframes shimmer {
    from { background-position: 200% 0; }
    to   { background-position: -200% 0; }
  }
</style>

<section id="contact" class="section section-dark" aria-labelledby="contact-heading">
  <div class="container">

    <div class="contact-grid">
      <div class="contact-copy reveal">
        <div class="eyebrow eyebrow-dark">Contact</div>
        <h2 id="contact-heading" class="section-h2 section-h2-light">
          Ready to build a stronger online presence?
        </h2>
        <p class="section-subline section-subline-light">
          Tell us about your business and we will recommend the simplest setup for your website, domain, email, SEO and monthly care.
        </p>

        <div class="contact-info">
          <div class="contact-row">
            <div class="contact-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 16s6-4.5 6-9A6 6 0 1 0 3 7c0 4.5 6 9 6 9z" stroke="#F59E0B" stroke-width="1.3" fill="none"/><circle cx="9" cy="7" r="2" stroke="#F59E0B" stroke-width="1.3"/></svg>
            </div>
            <div>
              <div class="contact-label">Location</div>
              <div class="contact-val">Australia-wide website support for local businesses</div>
            </div>
          </div>
          <div class="contact-row">
            <div class="contact-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><rect x="2" y="4" width="14" height="10" rx="2" stroke="#F59E0B" stroke-width="1.3" fill="none"/><path d="M2 5l7 5 7-5" stroke="#F59E0B" stroke-width="1.3" stroke-linecap="round"/></svg>
            </div>
            <div>
              <div class="contact-label">Email</div>
              <div class="contact-val"><a href="mailto:hello@readystackdigital.com">hello@readystackdigital.com</a></div>
            </div>
          </div>
          <div class="contact-row">
            <div class="contact-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="7" stroke="#F59E0B" stroke-width="1.3" fill="none"/><path d="M9 5.5v3.75l2.25 2.25" stroke="#F59E0B" stroke-width="1.3" stroke-linecap="round"/></svg>
            </div>
            <div>
              <div class="contact-label">Response</div>
              <div class="contact-val">
                We respond within 1 business day
                <span class="contact-note">Active care clients receive ongoing website checks.</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="contact-tab-container reveal reveal-delay-1">

        <div class="contact-tabs" role="tablist" aria-label="Contact options">
          <button
            class="contact-tab contact-tab--active"
            role="tab"
            id="tab-enquiry"
            aria-selected="true"
            aria-controls="panel-enquiry"
            data-tab="enquiry"
            type="button"
          >
            Send Enquiry
          </button>
          <button
            class="contact-tab"
            role="tab"
            id="tab-book"
            aria-selected="false"
            aria-controls="panel-book"
            data-tab="book"
            type="button"
          >
            <svg width="14" height="14" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M3.75 3.75h2.625L7.5 6.563 6.094 7.406a8.25 8.25 0 0 0 4.5 4.5L11.438 10.5l2.813 1.125-.75 2.625a1.125 1.125 0 0 1-1.125 1.125A11.25 11.25 0 0 1 2.625 4.875 1.125 1.125 0 0 1 3.75 3.75z" stroke="currentColor" stroke-width="1.3" fill="none"/>
            </svg>
            Book a Call
          </button>
        </div>

        <div id="panel-enquiry" role="tabpanel" aria-labelledby="tab-enquiry" class="contact-panel" tabindex="-1">

          <div class="contact-form-wrap">

            <div class="form-progress" aria-hidden="true">
              <div class="form-progress-step active" data-step="1">
                <div class="form-progress-dot">1</div>
                <span class="form-progress-label">About You</span>
              </div>
              <div class="form-progress-connector" data-after="1"></div>
              <div class="form-progress-step" data-step="2">
                <div class="form-progress-dot">2</div>
                <span class="form-progress-label">Your Business</span>
              </div>
              <div class="form-progress-connector" data-after="2"></div>
              <div class="form-progress-step" data-step="3">
                <div class="form-progress-dot">3</div>
                <span class="form-progress-label">Your Needs</span>
              </div>
            </div>

            <form id="contact-form" class="contact-form" action="https://api.web3forms.com/submit" method="post" novalidate aria-label="ReadyStack Digital enquiry form">
              <input type="hidden" name="access_key" value="44f5ac5c-31c8-4019-914b-8426212d137a" />
              <input type="hidden" name="subject" value="New enquiry from ReadyStack Digital website" />
              <input type="hidden" name="from_name" value="ReadyStack Digital Website" />
              <input type="checkbox" name="botcheck" style="display: none;" />

              <!-- Step 1: About You -->
              <div class="form-step active" data-step="1">
                <div class="form-row-2">
                  <div class="form-group">
                    <label for="first-name">First Name</label>
                    <input type="text" id="first-name" name="firstName" required autocomplete="given-name" placeholder="Monip" />
                  </div>
                  <div class="form-group">
                    <label for="last-name">Last Name</label>
                    <input type="text" id="last-name" name="lastName" required autocomplete="family-name" placeholder="Last Name" />
                  </div>
                </div>
                <div class="form-row-2">
                  <div class="form-group">
                    <label for="email">Business Email</label>
                    <input type="email" id="email" name="email" required autocomplete="email" placeholder="you@yourbusiness.com.au" />
                  </div>
                  <div class="form-group">
                    <label for="phone">Phone</label>
                    <input type="tel" id="phone" name="phone" autocomplete="tel" placeholder="0400 000 000" />
                  </div>
                </div>
                <div class="form-step-nav">
                  <button type="button" class="btn btn-amber btn-full form-next" data-next="2">
                    Next: Your Business
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </button>
                </div>
              </div>

              <!-- Step 2: Your Business -->
              <div class="form-step" data-step="2">
                <div class="form-group">
                  <label for="business">Business Name</label>
                  <input type="text" id="business" name="businessName" required autocomplete="organization" placeholder="Your Business Pty Ltd" />
                </div>
                <div class="form-group">
                  <label for="website">Current Website, if any</label>
                  <input type="url" id="website" name="website" autocomplete="url" placeholder="https://yourbusiness.com.au" />
                </div>
                <div class="form-group">
                  <label for="interest">What service are you interested in?</label>
                  <select id="interest" name="interest">
                    <option value="">Select a service</option>
                    <option value="landing-page">Landing Page Website</option>
                    <option value="business-website">Business Website</option>
                    <option value="redesign">Website Redesign</option>
                    <option value="domain-hosting">Domain and Hosting Setup</option>
                    <option value="business-email">Professional Business Email</option>
                    <option value="monthly-care">Monthly Website Care</option>
                    <option value="blog-support">Blog Support</option>
                    <option value="not-sure">Not Sure Yet</option>
                  </select>
                </div>
                <div class="form-step-nav">
                  <button type="button" class="btn btn-ghost form-back" data-back="1">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M11 7H3M7 3L3 7l4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    Back
                  </button>
                  <button type="button" class="btn btn-amber form-next form-nav-primary" data-next="3">
                    Next: Your Needs
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </button>
                </div>
              </div>

              <!-- Step 3: Your Needs -->
              <div class="form-step" data-step="3">
                <div class="form-row-2">
                  <div class="form-group">
                    <label for="domain-owned">Do you already own a domain?</label>
                    <select id="domain-owned" name="domainOwned">
                      <option value="">Select an option</option>
                      <option value="yes">Yes</option>
                      <option value="no">No</option>
                      <option value="not-sure">Not sure</option>
                    </select>
                  </div>
                  <div class="form-group">
                    <label for="email-needed">Need business email?</label>
                    <select id="email-needed" name="emailNeeded">
                      <option value="">Select an option</option>
                      <option value="yes">Yes</option>
                      <option value="no">No</option>
                      <option value="not-sure">Not sure</option>
                    </select>
                  </div>
                </div>
                <div class="form-group">
                  <label for="message">Tell us about your business</label>
                  <textarea id="message" name="message" rows="4" placeholder="What do you do, who do you serve, and what do you need help with?"></textarea>
                </div>
                <div class="h-captcha" data-captcha="true"></div>
                <div class="form-step-nav">
                  <button type="button" class="btn btn-ghost form-back" data-back="2">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M11 7H3M7 3L3 7l4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    Back
                  </button>
                  <button type="submit" class="btn btn-amber form-nav-primary" id="form-submit">
                    <span class="btn-label">Send Enquiry</span>
                    <span class="btn-spinner" aria-hidden="true">
                      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" class="spinning">
                        <circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="2" stroke-dasharray="22 22" stroke-linecap="round"/>
                      </svg>
                    </span>
                  </button>
                </div>
                <p class="form-note">Australia-wide website support for local businesses. We respond within 1 business day.</p>
              </div>

            </form>

            <div id="form-success" class="form-success" hidden aria-live="polite" role="status">
              <div class="success-icon" aria-hidden="true">
                <svg width="44" height="44" viewBox="0 0 44 44" fill="none">
                  <circle cx="22" cy="22" r="20" stroke="#10B981" stroke-width="2"/>
                  <path d="M13 22l7 7 11-13" stroke="#10B981" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <h3>Enquiry received.</h3>
              <p>We will review your details and respond within 1 business day.</p>
            </div>

          </div>
        </div>

        <div id="panel-book" role="tabpanel" aria-labelledby="tab-book" class="contact-panel" tabindex="-1" hidden>
          <div class="cal-header">
            <div class="cal-header-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 18 18" fill="none">
                <path d="M3.75 3.75h2.625L7.5 6.563 6.094 7.406a8.25 8.25 0 0 0 4.5 4.5L11.438 10.5l2.813 1.125-.75 2.625a1.125 1.125 0 0 1-1.125 1.125A11.25 11.25 0 0 1 2.625 4.875 1.125 1.125 0 0 1 3.75 3.75z" stroke="#F59E0B" stroke-width="1.3" fill="none"/>
              </svg>
            </div>
            <div>
              <h3 class="cal-header-title">Free 30-min Strategy Call</h3>
              <p class="cal-header-sub">No pitch. We'll review your goals and recommend the simplest path forward.</p>
            </div>
          </div>
          <div class="cal-wrap">
            <div class="cal-skeleton" id="cal-skeleton" aria-hidden="true">
              <div class="cal-skel-row cal-skel-row--wide"></div>
              <div class="cal-skel-row cal-skel-row--med"></div>
              <div class="cal-skel-block"></div>
              <div class="cal-skel-row cal-skel-row--short"></div>
              <div class="cal-skel-row cal-skel-row--med"></div>
            </div>
            <div id="cal-inline" style="width:100%;"></div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var tabs = document.querySelectorAll('.contact-tab');
    var panels = document.querySelectorAll('.contact-panel');
    var calInitialised = false;

    function activateTab(tabName) {
      tabs.forEach(function (t) {
        var isActive = t.dataset.tab === tabName;
        t.classList.toggle('contact-tab--active', isActive);
        t.setAttribute('aria-selected', String(isActive));
      });
      panels.forEach(function (p) {
        var isActive = p.id === 'panel-' + tabName;
        if (isActive) {
          p.removeAttribute('hidden');
        } else {
          p.setAttribute('hidden', '');
        }
      });
      var activePanel = document.getElementById('panel-' + tabName);
      if (activePanel) {
        activePanel.focus();
      }
      if (tabName === 'book') {
        initCalEmbed();
      }
    }

    function initCalEmbed() {
      if (calInitialised) return;
      calInitialised = true;
      var container = document.getElementById('cal-inline');
      if (!container) return;
      var skeleton = document.getElementById('cal-skeleton');
      var iframe = document.createElement('iframe');
      iframe.src = 'https://cal.com/readystack-digital-yyfaab/free-website-strategy-call?embed=true&theme=dark&layout=month_view&hideEventTypeDetails=false';
      iframe.style.cssText = 'width:100%;height:700px;border:none;border-radius:8px;display:block;opacity:0;transition:opacity 0.3s;';
      iframe.title = 'Book a free strategy call';
      iframe.loading = 'lazy';
      iframe.addEventListener('load', function () {
        iframe.style.opacity = '1';
        if (skeleton) skeleton.style.display = 'none';
      });
      container.innerHTML = '';
      container.appendChild(iframe);
    }

    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        activateTab(tab.dataset.tab);
      });
    });

    tabs.forEach(function (tab) {
      tab.addEventListener('keydown', function (e) {
        var tabsArray = Array.from(tabs);
        var idx = tabsArray.indexOf(tab);
        if (e.key === 'ArrowRight') {
          e.preventDefault();
          tabsArray[(idx + 1) % tabsArray.length].focus();
        } else if (e.key === 'ArrowLeft') {
          e.preventDefault();
          tabsArray[(idx - 1 + tabsArray.length) % tabsArray.length].focus();
        } else if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          activateTab(tab.dataset.tab);
        }
      });
    });

    document.querySelectorAll('[data-open-tab]').forEach(function (el) {
      el.addEventListener('click', function () {
        activateTab(el.dataset.openTab);
      });
    });
  })();
</script>
