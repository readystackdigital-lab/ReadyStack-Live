---
// Official platform glyphs (single-path SVG logos, viewBox 0 0 24 24)
const platforms = [
  { name: "Instagram", brand: "#E1306C", desc: "Visual content, service highlights, offers, testimonials, and behind-the-scenes posts.", icon: "M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" },
  { name: "Facebook", brand: "#1877F2", desc: "Local community updates, service posts, customer trust, and business announcements.", icon: "M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" },
  { name: "TikTok", brand: "#25F4EE", desc: "Short-form educational or promotional clips designed for discoverability and brand awareness.", icon: "M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z" },
  { name: "LinkedIn", brand: "#0A66C2", desc: "Professional updates, business credibility, founder and team content, and B2B trust.", icon: "M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" },
  { name: "Blog Posts", brand: "#10B981", desc: "SEO-friendly articles that support Google visibility and customer education.", icon: "M4 3h16a1 1 0 011 1v16a1 1 0 01-1 1H4a1 1 0 01-1-1V4a1 1 0 011-1zm3 5h10v2H7V8zm0 4h10v2H7v-2zm0 4h6v2H7v-2z" },
];
---

<section id="social-media-content" class="section section-dark social-section" aria-labelledby="social-heading">
  <div class="social-glow" aria-hidden="true"></div>
  <div class="container">

    <div class="social-layout">

      <!-- ── LEFT: copy ─────────────────────────────────────── -->
      <div class="social-copy reveal">
        <div class="eyebrow eyebrow-light">Social Media &amp; Content</div>
        <h2 id="social-heading" class="section-h2 section-h2-light social-h2">
          Keep your business visible<br>
          <span class="text-amber">beyond the website.</span>
        </h2>

        <p class="social-body">
          A strong website gives your business a proper home online. Consistent social media and blog content help people keep seeing, trusting, and remembering your brand.
        </p>
        <p class="social-body social-body-dim">
          We help small businesses create practical, branded content for Instagram, Facebook, TikTok, LinkedIn, and blog posts, aligned with your website, services, and business goals.
        </p>

        <ul class="social-bullets" role="list">
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M2.5 8l3.5 3.5 7.5-7.5" stroke="#10B981" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Social posts that match your brand
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M2.5 8l3.5 3.5 7.5-7.5" stroke="#10B981" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Captions written for clarity and trust
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M2.5 8l3.5 3.5 7.5-7.5" stroke="#10B981" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Blog content that supports SEO
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M2.5 8l3.5 3.5 7.5-7.5" stroke="#10B981" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Content ideas based on your services
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M2.5 8l3.5 3.5 7.5-7.5" stroke="#10B981" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Consistent visuals across your online presence
          </li>
        </ul>

        <div class="social-cta-row">
          <a href="/contact" class="btn btn-amber btn-lg">Add social media support</a>
          <a href="/contact#book" class="btn btn-outline btn-lg">Ask about content support</a>
        </div>
      </div><!-- /social-copy -->

      <!-- ── RIGHT: animated content dashboard ──────────────── -->
      <div class="social-stage" aria-hidden="true">

        <!-- Phone — Instagram-style post preview -->
        <div class="sc-phone sc-anim sc-float-slow">
          <div class="sc-phone-notch"></div>
          <div class="sc-phone-screen">
            <div class="sc-ig-head">
              <span class="sc-avatar"></span>
              <div class="sc-ig-head-text">
                <span class="sc-ig-handle">readystack.client</span>
                <span class="sc-ig-sub">Sponsored</span>
              </div>
              <span class="sc-ig-dots">•••</span>
            </div>
            <div class="sc-ig-image">
              <span class="sc-ig-image-tag">New service launch</span>
            </div>
            <div class="sc-ig-actions">
              <span class="sc-ig-ico sc-heart"></span>
              <span class="sc-ig-ico sc-comment"></span>
              <span class="sc-ig-ico sc-share"></span>
              <span class="sc-ig-save"></span>
            </div>
            <div class="sc-ig-caption">
              <span class="sc-line sc-line-90"></span>
              <span class="sc-line sc-line-60"></span>
            </div>
          </div>
        </div>

        <!-- Floating: TikTok-style reel card -->
        <div class="sc-card sc-reel sc-anim sc-float-a">
          <div class="sc-reel-thumb">
            <span class="sc-play"></span>
          </div>
          <div class="sc-reel-meta">
            <span class="sc-chip sc-chip-tiktok">TikTok</span>
            <span class="sc-reel-dur">0:18</span>
          </div>
        </div>

        <!-- Floating: LinkedIn update card -->
        <div class="sc-card sc-linkedin sc-anim sc-float-b">
          <div class="sc-li-head">
            <span class="sc-avatar sc-avatar-sm"></span>
            <div>
              <span class="sc-li-name">Business update</span>
              <span class="sc-chip sc-chip-linkedin">LinkedIn</span>
            </div>
          </div>
          <span class="sc-line sc-line-100"></span>
          <span class="sc-line sc-line-75"></span>
        </div>

        <!-- Floating: Blog article preview -->
        <div class="sc-card sc-blog sc-anim sc-float-c">
          <span class="sc-chip sc-chip-blog">Blog · SEO</span>
          <span class="sc-blog-title">5 things local customers look for online</span>
          <span class="sc-line sc-line-90"></span>
          <span class="sc-line sc-line-50"></span>
        </div>

        <!-- Floating: content calendar -->
        <div class="sc-card sc-calendar sc-anim sc-float-d">
          <div class="sc-cal-head">Content plan</div>
          <div class="sc-cal-grid">
            <span></span><span class="on"></span><span></span><span class="on amber"></span>
            <span class="on"></span><span></span><span class="on"></span><span></span>
            <span class="on amber"></span><span></span><span class="on"></span><span class="on"></span>
          </div>
        </div>

        <!-- Floating: metric chips -->
        <div class="sc-metric-card sc-anim sc-float-e">
          <span class="sc-metric-val">+38%</span>
          <span class="sc-metric-lbl">Reach</span>
        </div>
        <div class="sc-metric-card sc-metric-green sc-anim sc-float-f">
          <span class="sc-metric-val">12</span>
          <span class="sc-metric-lbl">Posts scheduled</span>
        </div>

        <!-- Floating: "Ready to publish" badge -->
        <div class="sc-badge sc-anim sc-float-g">
          <span class="sc-badge-dot"></span>
          Ready to publish
        </div>

        <!-- Floating: notification bubble -->
        <div class="sc-notif sc-anim">
          <span class="sc-notif-ico">✎</span>
          <span>Caption drafted</span>
        </div>

        <!-- Platform chips -->
        <div class="sc-chips-float sc-anim sc-float-h">
          <span class="sc-chip sc-chip-ig">Instagram</span>
          <span class="sc-chip sc-chip-fb">Facebook</span>
        </div>
      </div><!-- /social-stage -->

    </div><!-- /social-layout -->

    <!-- ── Platform cards ───────────────────────────────────── -->
    <div class="platform-head reveal">
      <h3 class="platform-head-title">One content system across every platform</h3>
      <p class="platform-head-sub">Recreated UI patterns, not screenshots, to show how your brand stays consistent online.</p>
    </div>

    <div class="platform-grid">
      {platforms.map((p, i) => (
        <article class={`platform-card reveal ${i ? `reveal-delay-${Math.min(i, 4)}` : ""}`} style={`--brand:${p.brand}`}>
          <div class="platform-card-top">
            <span class="platform-logo" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d={p.icon}></path></svg>
            </span>
            <span class="platform-name">{p.name}</span>
          </div>
          <p class="platform-card-desc">{p.desc}</p>
        </article>
      ))}
    </div>

    <!-- ── Social content mini-process ──────────────────────── -->
    <div class="social-process reveal">
      <div class="social-process-label">How content support works</div>
      <ol class="social-process-steps" role="list">
        <li><span class="sp-num">1</span> Brand &amp; content direction</li>
        <li><span class="sp-num">2</span> Monthly content plan</li>
        <li><span class="sp-num">3</span> Post design, captions &amp; blog topics</li>
        <li><span class="sp-num">4</span> Review &amp; publish support</li>
        <li><span class="sp-num">5</span> Ongoing improvement</li>
      </ol>
    </div>

  </div>
</section>

<style>
  /* ═══════════════════════════════════════════════════════════
     Social Media & Content — premium dark showcase
  ═══════════════════════════════════════════════════════════ */
  .social-section {
    background: radial-gradient(circle at 78% 22%, #15110a 0%, transparent 46%),
                radial-gradient(circle at 12% 80%, #0a1410 0%, transparent 42%),
                #0B0D10;
    color: var(--white);
    isolation: isolate;
  }

  .social-glow {
    position: absolute;
    top: 8%;
    right: -6%;
    width: 540px;
    height: 540px;
    max-width: 70vw;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(245,158,11,.16), transparent 64%);
    filter: blur(30px);
    pointer-events: none;
    z-index: 0;
  }

  .social-layout {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.02fr);
    align-items: center;
    gap: clamp(2.5rem, 5vw, 5rem);
  }

  /* ── Left copy ─────────────────────────────────────────── */
  .social-copy .social-h2 {
    text-align: left;
    margin-inline: 0;
    max-width: 16ch;
  }

  .social-body {
    font-size: var(--text-md);
    line-height: 1.75;
    color: rgba(255,255,255,.78);
    max-width: 52ch;
    margin-bottom: var(--space-4);
  }

  .social-body-dim { color: rgba(255,255,255,.58); }

  .social-bullets {
    list-style: none;
    display: grid;
    gap: .7rem;
    margin: var(--space-6) 0 var(--space-8);
  }

  .social-bullets li {
    display: flex;
    align-items: center;
    gap: .65rem;
    font-size: var(--text-sm);
    color: rgba(255,255,255,.82);
  }

  .social-bullets svg { flex-shrink: 0; }

  .social-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: .8rem;
  }

  /* Outline button needs light treatment on dark bg */
  .social-cta-row .btn-outline {
    border-color: rgba(255,255,255,.22);
    color: rgba(255,255,255,.86);
  }
  .social-cta-row .btn-outline:hover {
    border-color: var(--amber);
    color: #fff;
    background: rgba(245,158,11,.08);
  }

  /* ── Right stage ───────────────────────────────────────── */
  .social-stage {
    position: relative;
    min-height: 520px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Entrance + float base */
  .sc-anim {
    opacity: 0;
    animation: sc-rise .8s cubic-bezier(.16,1,.3,1) both;
  }
  @keyframes sc-rise {
    from { opacity: 0; transform: translateY(20px) scale(.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* Continuous gentle float layered on top of entrance */
  @keyframes sc-bob {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-9px); }
  }

  /* Phone */
  .sc-phone {
    position: relative;
    z-index: 3;
    width: 224px;
    height: 460px;
    border-radius: 34px;
    background: linear-gradient(160deg, #1b1f27, #0e1116);
    border: 1px solid rgba(255,255,255,.12);
    box-shadow: 0 40px 90px rgba(0,0,0,.55), 0 0 0 6px rgba(255,255,255,.03);
    padding: 12px;
    animation-delay: .05s;
  }
  .sc-float-slow { animation-name: sc-rise, sc-bob; animation-duration: .8s, 7s; animation-timing-function: cubic-bezier(.16,1,.3,1), ease-in-out; animation-iteration-count: 1, infinite; animation-delay: .05s, .85s; }

  .sc-phone-notch {
    position: absolute;
    top: 12px; left: 50%; transform: translateX(-50%);
    width: 84px; height: 16px;
    border-radius: 0 0 12px 12px;
    background: #0e1116;
    z-index: 2;
  }
  .sc-phone-screen {
    height: 100%;
    border-radius: 24px;
    background: #0f1217;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .sc-ig-head {
    display: flex;
    align-items: center;
    gap: .5rem;
    padding: 1.1rem .8rem .55rem;
  }
  .sc-avatar {
    width: 30px; height: 30px; border-radius: 50%;
    background: conic-gradient(from 210deg, #F59E0B, #FCD34D, #10B981, #F59E0B);
    flex-shrink: 0;
  }
  .sc-avatar-sm { width: 24px; height: 24px; }
  .sc-ig-head-text { display: flex; flex-direction: column; line-height: 1.2; flex: 1; }
  .sc-ig-handle { font-size: .72rem; font-weight: 600; color: #fff; }
  .sc-ig-sub { font-size: .6rem; color: rgba(255,255,255,.42); }
  .sc-ig-dots { color: rgba(255,255,255,.5); font-size: .7rem; letter-spacing: 1px; }

  .sc-ig-image {
    position: relative;
    aspect-ratio: 1;
    margin: 0 .55rem;
    border-radius: 12px;
    background:
      radial-gradient(circle at 30% 30%, rgba(245,158,11,.4), transparent 55%),
      linear-gradient(135deg, #2a2118, #14181f 70%);
    border: 1px solid rgba(255,255,255,.06);
    overflow: hidden;
  }
  .sc-ig-image::after {
    content: "";
    position: absolute; inset: 0;
    background: repeating-linear-gradient(115deg, transparent 0 18px, rgba(255,255,255,.025) 18px 19px);
  }
  .sc-ig-image-tag {
    position: absolute; bottom: 8px; left: 8px;
    font-size: .58rem; font-weight: 600;
    color: #0B0D10; background: var(--amber);
    padding: 3px 7px; border-radius: 6px;
  }

  .sc-ig-actions {
    display: flex; align-items: center; gap: .65rem;
    padding: .7rem .8rem .35rem;
  }
  .sc-ig-ico { width: 16px; height: 16px; border-radius: 4px; background: rgba(255,255,255,.32); }
  .sc-heart { -webkit-mask: none; background: rgba(245,158,11,.85); border-radius: 50% 50% 0 50%; transform: rotate(45deg); }
  .sc-ig-save { width: 14px; height: 16px; margin-left: auto; background: rgba(255,255,255,.3); clip-path: polygon(0 0,100% 0,100% 100%,50% 78%,0 100%); }

  .sc-ig-caption { padding: .25rem .8rem 1rem; display: flex; flex-direction: column; gap: .4rem; }

  .sc-line { display: block; height: 7px; border-radius: 4px; background: rgba(255,255,255,.12); }
  .sc-line-100 { width: 100%; }
  .sc-line-90 { width: 90%; }
  .sc-line-75 { width: 75%; }
  .sc-line-60 { width: 60%; }
  .sc-line-50 { width: 50%; }

  /* Floating cards — shared */
  .sc-card {
    position: absolute;
    background: rgba(20, 24, 31, .92);
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 16px;
    padding: .85rem;
    box-shadow: 0 24px 50px rgba(0,0,0,.45);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    z-index: 4;
    display: flex;
    flex-direction: column;
    gap: .45rem;
  }

  /* Chips */
  .sc-chip {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: .62rem;
    font-weight: 600;
    letter-spacing: .02em;
    padding: 3px 9px;
    border-radius: 999px;
    white-space: nowrap;
  }
  .sc-chip-ig       { color: #FCD34D; background: rgba(245,158,11,.14); border: 1px solid rgba(245,158,11,.3); }
  .sc-chip-fb       { color: #93b4ff; background: rgba(59,130,246,.14); border: 1px solid rgba(59,130,246,.32); }
  .sc-chip-tiktok   { color: #f5f5f5; background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.22); }
  .sc-chip-linkedin { color: #7fb6ff; background: rgba(59,130,246,.12); border: 1px solid rgba(59,130,246,.28); }
  .sc-chip-blog     { color: #6ee7b7; background: rgba(16,185,129,.12); border: 1px solid rgba(16,185,129,.3); }

  /* Reel card */
  .sc-reel { top: 4%; left: -4%; width: 140px; }
  .sc-reel-thumb {
    position: relative;
    aspect-ratio: 9/13;
    border-radius: 10px;
    background: linear-gradient(150deg, #241c12, #11151c);
    border: 1px solid rgba(255,255,255,.07);
    display: flex; align-items: center; justify-content: center;
  }
  .sc-play {
    width: 0; height: 0;
    border-left: 16px solid rgba(255,255,255,.92);
    border-top: 10px solid transparent;
    border-bottom: 10px solid transparent;
    filter: drop-shadow(0 0 10px rgba(245,158,11,.6));
    margin-left: 4px;
  }
  .sc-reel-meta { display: flex; align-items: center; justify-content: space-between; }
  .sc-reel-dur { font-size: .62rem; color: rgba(255,255,255,.5); font-family: var(--font-mono); }

  /* LinkedIn card */
  .sc-linkedin { bottom: 6%; left: -7%; width: 184px; }
  .sc-li-head { display: flex; align-items: center; gap: .5rem; margin-bottom: .15rem; }
  .sc-li-head > div { display: flex; flex-direction: column; gap: .25rem; }
  .sc-li-name { font-size: .72rem; font-weight: 600; color: #fff; }

  /* Blog card */
  .sc-blog { top: 8%; right: -8%; width: 196px; }
  .sc-blog-title { font-size: .78rem; font-weight: 600; color: #fff; line-height: 1.35; }

  /* Calendar card */
  .sc-calendar { bottom: 4%; right: -5%; width: 172px; }
  .sc-cal-head { font-size: .68rem; font-weight: 600; color: rgba(255,255,255,.78); }
  .sc-cal-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 5px; }
  .sc-cal-grid span {
    aspect-ratio: 1; border-radius: 4px; background: rgba(255,255,255,.07);
  }
  .sc-cal-grid span.on { background: rgba(16,185,129,.45); }
  .sc-cal-grid span.on.amber { background: rgba(245,158,11,.7); }

  /* Metric cards */
  .sc-metric-card {
    position: absolute;
    z-index: 5;
    background: rgba(20, 24, 31, .95);
    border: 1px solid rgba(245,158,11,.28);
    border-radius: 13px;
    padding: .55rem .8rem;
