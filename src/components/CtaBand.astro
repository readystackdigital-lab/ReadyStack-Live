---
export interface Props {
  eyebrow?: string;
  heading: string;        // may contain inline HTML
  sub?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  bookCta?: boolean;
}

const {
  eyebrow = "Ready when you are",
  heading,
  sub,
  primaryLabel = "Get a Quote",
  primaryHref = "/contact",
  secondaryLabel = "Book a Call",
  secondaryHref = "/contact#book",
} = Astro.props;
---

<section class="cta-band" aria-label="Get started with ReadyStack Digital">
  <div class="cta-band-glow" aria-hidden="true"></div>
  <div class="container">
    <div class="cta-band-card reveal">
      {eyebrow && <div class="eyebrow eyebrow-light">{eyebrow}</div>}
      <h2 class="cta-band-title" set:html={heading}></h2>
      {sub && <p class="cta-band-sub">{sub}</p>}
      <div class="cta-band-actions">
        <a href={primaryHref} class="btn btn-amber btn-lg">{primaryLabel}</a>
        <a href={secondaryHref} class="btn btn-page-ghost btn-lg">{secondaryLabel}</a>
      </div>
      <p class="cta-band-trust">Nationwide · No lock-in contracts · Friendly, jargon-free support</p>
    </div>
  </div>
</section>

<style>
  .cta-band {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    background: #0B0D10;
    padding-block: clamp(3.5rem, 7vw, 6rem);
  }
  .cta-band-glow {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at 50% 0%, rgba(245, 158, 11, 0.16), transparent 55%);
  }
  .cta-band-card {
    position: relative;
    z-index: 1;
    max-width: 760px;
    margin-inline: auto;
    text-align: center;
    background: linear-gradient(160deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02));
    border: 1px solid rgba(245, 158, 11, 0.22);
    border-radius: var(--radius-xl);
    padding: clamp(2rem, 5vw, 3.25rem);
    box-shadow: 0 30px 70px rgba(0, 0, 0, 0.45), inset 0 0 60px rgba(245, 158, 11, 0.04);
  }
  .cta-band-card .eyebrow { justify-content: center; }
  .cta-band-title {
    font-family: var(--font-display);
    font-weight: var(--weight-bold);
    font-size: clamp(1.8rem, 1.2rem + 2.4vw, 2.8rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #fff;
    text-wrap: balance;
    margin: 0;
  }
  .cta-band-sub {
    margin: clamp(0.9rem, 2vw, 1.2rem) auto 0;
    max-width: 54ch;
    font-size: var(--text-md);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.66);
  }
  .cta-band-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.8rem;
    margin-top: clamp(1.5rem, 3vw, 2rem);
  }
  .cta-band-trust {
    margin-top: 1.25rem;
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.45);
  }
</style>
