---
/*
  ──────────────────────────────────────────────────────────────
  ReadyStack Digital — Homepage Hero · "Studio Desk"  (v4)
  ──────────────────────────────────────────────────────────────
  Reference-matched layout (client-supplied "IdeoMax" hero comp):
  eyebrow pill → headline → subhead → two CTAs → proof pills, set
  against a right-side video panel in an organic single-corner
  blob mask, with a floating cream service card and a hand-drawn
  connector arrow. A full-bleed marquee strip closes out the
  section, reusing the site's existing marquee convention
  (see TrustStrip.astro / public/css/layout.css `.marquee-*`).

  Content: original hero copy verbatim (headline/sub/CTAs/proof).
  Video: public/assets/video/hero-video.mp4 (developer at a
  multi-monitor desk — client-supplied, matches the reference's
  "person working at a desk" mood exactly).

  Brand: amber (--accent) + charcoal. The floating card is the
  one deliberate light-on-dark accent (cream, not white) — the
  single boldest move in the composition, matching the reference.

  Stack: Astro static. Vanilla TS + GSAP + Lenis in a bundled
  <script>. Content server-rendered, crawlable, JS-independent
  (intro + marquee are pure CSS).
*/

const proofItems = [
  'SEO-ready websites',
  'Professional email options',
  'Secure hosting setup',
  'Domain and DNS managed',
  'Monthly website care',
  'Social & blog content',
  '24/7 AI agent & reception',
];

const marqueeItems = [
  'Website Design', 'Business Email', 'SEO', 'Website Care',
  'Social Content', 'AI Agent & Reception', 'Secure Hosting', 'Domain & DNS',
];
---

<section id="hero" aria-label="Hero: ReadyStack Digital website, domain, email, SEO and care">

  <!-- ── Background: charcoal base + amber aurora + dot grid + grain ── -->
  <div class="hero-bg" aria-hidden="true">
    <div class="bg-aurora"></div>
    <div class="bg-dots"></div>
    <div class="bg-grain"></div>
  </div>

  <div class="hero-wrap">
    <div class="hero-inner">

      <!-- ══════════════════════════════════════════════════════
           CONTENT — real, crawlable, JS-independent HTML
           (headline/sub/CTAs copy preserved verbatim)
      ══════════════════════════════════════════════════════ -->
      <div class="hero-text">
        <span class="hero-eyebrow">
          <span class="eyebrow-dot" aria-hidden="true"></span>
          Website • Email • SEO • Care • Social • AI Agent
        </span>

        <h1 class="hero-headline">
          Your website, email, SEO, and social content,
          <span class="headline-amber">built, managed, and kept visible</span>
          <span class="headline-outline">without the stress.</span>
        </h1>

        <p class="hero-sub">
          ReadyStack Digital helps small businesses build a professional online presence: websites, business email, AI Agent, SEO, and secure monthly care, plus branded social media content that keeps your brand active and visible.
        </p>

        <div class="hero-ctas">
          <a href="/contact" class="btn btn-amber btn-lg magnetic">
            <span>Get a Quote</span>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M3 9h12M9 3l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="/packages" class="btn btn-hero-ghost btn-lg">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.5"/>
              <path d="M7 6.5l4 2.5-4 2.5V6.5z" fill="currentColor"/>
            </svg>
            <span>View Packages</span>
          </a>
        </div>

        <p class="hero-trust">Websites from $1,000. Managed care from $100/month.</p>

        <div class="hero-support">
          <div class="hero-book-link">
            <svg width="13" height="13" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M3.75 3.75h2.625L7.5 6.563 6.094 7.406a8.25 8.25 0 0 0 4.5 4.5L11.438 10.5l2.813 1.125-.75 2.625a1.125 1.125 0 0 1-1.125 1.125A11.25 11.25 0 0 1 2.625 4.875 1.125 1.125 0 0 1 3.75 3.75z" stroke="currentColor" stroke-width="1.3" fill="none"/>
            </svg>
            Prefer to talk first?&nbsp;<a href="/contact#book" class="hero-book-link__anchor">Book a free 30-min strategy call</a>, no commitment
          </div>

          <div class="hero-proof">
            {proofItems.map((label) => (
              <span class="proof-item">
                <svg width="14" height="14" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path d="M2 7.5l4 4 7-7" stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {label}
              </span>
            ))}
          </div>
        </div>
      </div><!-- /hero-text -->

      <!-- ══════════════════════════════════════════════════════
           VISUAL — video panel (organic blob mask) + floating
           service card + hand-drawn connector arrow
      ══════════════════════════════════════════════════════ -->
      <div class="hero-visual">
        <!-- .visual-scroll is the GSAP scroll-parallax target: kept
             separate from .hero-visual because a stale global rule
             (`.hero-visual { transform: none !important }` at ≤1024px
             in public/css/components.css) would otherwise fight the
             scroll-driven transform on the shared class name. -->
        <div class="visual-scroll">
          <div class="visual-glow" aria-hidden="true"></div>

          <div class="video-frame">
            <video
              class="video-el"
              src="/assets/video/hero-video.mp4"
              autoplay
              loop
              muted
              playsinline
              preload="none"
              aria-hidden="true"
            ></video>
            <div class="video-sheen" aria-hidden="true"></div>
          </div>

          <svg class="connector-arrow" viewBox="0 0 180 130" fill="none" aria-hidden="true">
            <path class="connector-path" d="M8 14C36 10 58 26 50 46C44 62 20 60 22 78C24 96 56 92 70 104C82 114 96 116 108 112"
              stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-dasharray="4 7"/>
            <path d="M100 106l10 8-2-13" stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          </svg>

          <a href="#ai-agent" class="floating-card">
            <span class="floating-card-icon" aria-hidden="true">
              <svg width="19" height="19" viewBox="0 0 18 18" fill="none">
                <path d="M8 2v2M4 6h8a1 1 0 0 1 1 1v4a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1zM6 9h.01M10 9h.01" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <span class="floating-card-copy">
              <strong>AI Agent &amp;<br>Reception</strong>
              <span class="floating-card-sub">New — from $1,500 setup</span>
            </span>
          </a>
        </div><!-- /visual-scroll -->
      </div><!-- /hero-visual -->

    </div><!-- /hero-inner -->
  </div><!-- /hero-wrap -->

  <!-- ══════════════════════════════════════════════════════
       Bottom marquee strip — reuses the site's existing
       marquee-outer/track/set convention (see TrustStrip.astro)
  ══════════════════════════════════════════════════════ -->
  <div class="hero-marquee" aria-hidden="true">
    <div class="marquee-outer">
      <div class="marquee-track">
        <div class="marquee-set">
          {marqueeItems.map((label) => (
            <span class="marquee-item">
              <svg width="13" height="13" viewBox="0 0 16 16" fill="none" class="marquee-spark"><path d="M8 1l1.4 4.6L14 7l-4.6 1.4L8 13l-1.4-4.6L2 7l4.6-1.4z" fill="#F59E0B"/></svg>
              {label}
            </span>
          ))}
        </div>
        <div class="marquee-set">
          {marqueeItems.map((label) => (
            <span class="marquee-item">
              <svg width="13" height="13" viewBox="0 0 16 16" fill="none" class="marquee-spark"><path d="M8 1l1.4 4.6L14 7l-4.6 1.4L8 13l-1.4-4.6L2 7l4.6-1.4z" fill="#F59E0B"/></svg>
              {label}
            </span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  html.lenis, html.lenis body { height: auto; }
  .lenis.lenis-smooth { scroll-behavior: auto !important; }
  .lenis.lenis-smooth [data-lenis-prevent] { overscroll-behavior: contain; }
  .lenis.lenis-stopped { overflow: clip; }
  .lenis.lenis-smooth iframe { pointer-events: none; }
</style>

<style>
  /* ═══════════════════════════════════════════════════════════
     SHELL + palette
  ═══════════════════════════════════════════════════════════ */
  #hero {
    --accent: var(--amber, #F59E0B);
    --accent-2: var(--amber-300, #FCD34D);
    --cream: #FAF6EF;
    position: relative;
    /* beat stale global `#hero` rules (display:flex + padding-top) */
    display: block;
    padding: 0;
    overflow: hidden;
    isolation: isolate;
    background:
      radial-gradient(95% 85% at 82% 6%, rgba(245,158,11,.13), transparent 52%),
      radial-gradient(70% 65% at 4% 96%, rgba(245,158,11,.05), transparent 60%),
      linear-gradient(163deg, #16181e 0%, #0d0f13 52%, #0a0c0f 100%);
  }

  /* ── Background layers ─────────────────────────────────── */
  .hero-bg { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
  .bg-aurora {
    position: absolute; inset: -12%;
    background:
      radial-gradient(34% 44% at 78% 26%, rgba(245,158,11,.16), transparent 70%),
      radial-gradient(26% 34% at 18% 80%, rgba(252,211,77,.06), transparent 70%);
    filter: blur(22px);
    animation: aurora-breathe 12s ease-in-out infinite;
  }
  @keyframes aurora-breathe {
    0%, 100% { opacity: 1; transform: translate3d(0,0,0); }
    50%      { opacity: .8; transform: translate3d(-1.5%, 1.5%, 0); }
  }
  .bg-dots {
    position: absolute; inset: 0;
    background-image: radial-gradient(rgba(255,255,255,.06) 1px, transparent 1.4px);
    background-size: 26px 26px;
    mask-image: radial-gradient(75% 75% at 68% 38%, #000 0%, transparent 78%);
    -webkit-mask-image: radial-gradient(75% 75% at 68% 38%, #000 0%, transparent 78%);
  }
  .bg-grain {
    position: absolute; inset: 0; opacity: .13; mix-blend-mode: soft-light;
    background: url('/images/hero/grain.webp') repeat; background-size: 320px 320px;
  }

  /* ═══════════════════════════════════════════════════════════
     LAYOUT — editorial left, video panel right
  ═══════════════════════════════════════════════════════════ */
  .hero-wrap {
    position: relative; z-index: 1;
    width: min(1280px, calc(100% - 56px));
    margin-inline: auto;
    display: flex; align-items: center;
    padding: calc(var(--nav-h, 72px) + clamp(2rem, 4.5vh, 3.4rem)) 0 clamp(2.6rem, 5vh, 3.6rem);
  }
  #hero .hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(0, .92fr);
    align-items: center;
    gap: clamp(2rem, 4.5vw, 4.5rem);
    width: 100%;
  }
  .hero-text { position: relative; max-width: 600px; text-align: left; }

  .hero-eyebrow {
    display: inline-flex; align-items: center; gap: .55rem;
    padding: .5rem 1rem; border-radius: 999px;
    background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.14);
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
    font-family: var(--font-mono); font-size: .72rem; letter-spacing: .06em;
    color: rgba(255,255,255,.78);
    margin-bottom: clamp(1.1rem, 2vw, 1.6rem);
  }
  .eyebrow-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); flex: 0 0 auto; animation: eyebrow-pulse 2.4s ease-in-out infinite; }
  @keyframes eyebrow-pulse { 0%,100% { opacity: 1; } 50% { opacity: .4; } }

  #hero .hero-headline {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.3rem, 3.3vw, 3.5rem);
    line-height: 1.08;
    letter-spacing: -0.045em;
    color: #fff;
  }
  #hero .headline-amber {
    color: var(--accent);
    text-shadow: 0 0 46px rgba(245,158,11,.4), 0 0 110px rgba(245,158,11,.15);
  }
  #hero .headline-outline {
    color: rgba(255,255,255,.08); -webkit-text-stroke: 1.2px rgba(255,255,255,.6);
  }

  #hero .hero-sub {
    max-width: 540px;
    margin-top: clamp(1rem, 1.8vw, 1.4rem);
    font-size: clamp(1rem, 1.05vw, 1.08rem);
    line-height: 1.68;
    color: rgba(255,255,255,.72);
  }

  .hero-ctas { display: flex; align-items: center; flex-wrap: wrap; gap: .75rem; margin-top: clamp(1.4rem, 2.2vw, 1.9rem); }
  .hero-ctas .btn { min-height: 48px; }

  .hero-trust { margin-top: 1.1rem; font-size: .82rem; color: rgba(255,255,255,.6); }

  .hero-support { margin-top: clamp(1.3rem, 2vw, 1.7rem); padding-top: 1.1rem; border-top: 1px solid rgba(255,255,255,.08); }
  .hero-book-link { display: flex; align-items: center; gap: .35rem; font-size: .78rem; color: rgba(255,255,255,.6); flex-wrap: wrap; line-height: 1.5; }
  .hero-book-link svg { flex-shrink: 0; color: rgba(255,255,255,.6); }
  .hero-book-link__anchor { color: var(--accent); text-decoration: none; font-weight: 600; }
  .hero-book-link__anchor:hover { text-decoration: underline; text-underline-offset: 3px; }
  .hero-proof { display: flex; align-items: center; flex-wrap: wrap; gap: .42rem; margin-top: .85rem; }
  .proof-item {
    display: inline-flex; align-items: center; gap: .38rem;
    padding: .3rem .56rem; border: 1px solid rgba(255,255,255,.1); border-radius: 999px;
    background: rgba(255,255,255,.04); color: rgba(255,255,255,.66);
    font-size: .74rem; line-height: 1.2;
    transition: border-color .22s, background .22s, color .22s;
  }
  .proof-item svg { flex: 0 0 auto; }
  .proof-item:hover { border-color: rgba(245,158,11,.32); background: rgba(245,158,11,.07); color: rgba(255,255,255,.88); }

  .btn-hero-ghost {
    display: inline-flex; align-items: center; justify-content: center; gap: .5rem;
    font-family: var(--font-display); font-weight: var(--weight-semibold); font-size: var(--text-md);
    padding: .85rem 1.85rem; min-height: 48px;
    background: rgba(255,255,255,.04); color: rgba(255,255,255,.8);
    border: 1.5px solid rgba(255,255,255,.2); border-radius: var(--radius-full);
    cursor: pointer; text-decoration: none; white-space: nowrap;
    transition: background .18s, color .18s, border-color .18s, transform .18s;
  }
  .btn-hero-ghost:hover { background: rgba(255,255,255,.09); color: #EEEFF2; border-color: rgba(255,255,255,.36); transform: translateY(-1px); }
  .btn-hero-ghost:active { transform: scale(.97); }

  .hero-ctas .btn-amber { position: relative; overflow: hidden; }
  .hero-ctas .btn-amber::after {
    content:''; position: absolute; inset: 0; border-radius: inherit; pointer-events: none;
    background: linear-gradient(108deg, transparent 30%, rgba(255,255,255,.26) 50%, transparent 70%);
    background-size: 200% 100%; animation: btn-gleam 3.4s ease-in-out 2.4s infinite;
  }
  @keyframes btn-gleam { 0%{ background-position:180% center; opacity:0; } 18%{opacity:1;} 82%{opacity:1;} 100%{ background-position:-80% center; opacity:0; } }

  /* ═══════════════════════════════════════════════════════════
     VISUAL — video panel, floating card, connector arrow
  ═══════════════════════════════════════════════════════════ */
  /* explicit `display: block` + reset cancels a stale global
     `.hero-visual { display: flex; align-items: center }` rule
     (components.css) that otherwise flex-shrinks .video-frame to
     near-zero, since it has no intrinsic content to size from. */
  .hero-visual {
    display: block;
    position: relative; width: 100%; max-width: 480px; margin-inline: auto;
    justify-content: normal; align-items: normal;
  }
  .visual-scroll { position: relative; width: 100%; }

  .visual-glow {
    position: absolute; inset: -12%;
    background: radial-gradient(60% 55% at 60% 35%, rgba(245,158,11,.22), transparent 70%);
    filter: blur(30px);
    pointer-events: none;
  }

  /* organic single-corner blob mask — the signature shape */
  .video-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 4.35;
    border-radius: 28px 28px 46% 28px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,.14);
    box-shadow: 0 40px 90px -30px rgba(0,0,0,.65), inset 0 1px 0 rgba(255,255,255,.1);
    will-change: transform;
  }
  .video-el {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    transform: scale(1.08);
    filter: saturate(.92) brightness(.86) contrast(1.04);
  }
  .video-sheen {
    position: absolute; inset: 0;
    background: linear-gradient(200deg, rgba(245,158,11,.14), transparent 40%, rgba(10,12,16,.35) 100%);
    mix-blend-mode: normal;
    pointer-events: none;
  }

  /* hand-drawn connector arrow, text-column → floating card */
  .connector-arrow {
    position: absolute; left: -13%; bottom: 6%;
    width: 34%; height: auto;
    overflow: visible;
    pointer-events: none;
  }
  .connector-path { stroke-dashoffset: 0; }

  /* floating cream service card — the one deliberate light accent */
  .floating-card {
    position: absolute; left: -9%; bottom: -8%;
    display: flex; align-items: center; gap: .8rem;
    max-width: 232px;
    padding: 1rem 1.15rem;
    border-radius: 20px;
    background: var(--cream);
    box-shadow: 0 26px 50px -16px rgba(0,0,0,.5), 0 0 0 1px rgba(0,0,0,.03);
    text-decoration: none;
    transition: transform .32s cubic-bezier(.22,1,.36,1), box-shadow .32s ease;
  }
  .floating-card:hover { transform: translateY(-4px); box-shadow: 0 34px 60px -16px rgba(0,0,0,.55), 0 0 0 1px rgba(0,0,0,.03); }
  .floating-card-icon {
    flex: 0 0 auto; width: 40px; height: 40px; border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, var(--accent), #d97a06);
    color: #1a1206;
  }
  .floating-card-copy { display: flex; flex-direction: column; gap: .18rem; }
  .floating-card-copy strong {
    font-family: var(--font-display); font-size: .92rem; line-height: 1.15;
    letter-spacing: -.01em; color: #1c1710;
  }
  .floating-card-sub { font-size: .72rem; color: #6b6255; font-weight: 500; }

  /* ═══════════════════════════════════════════════════════════
     BOTTOM MARQUEE STRIP — full-bleed, reuses site marquee convention
  ═══════════════════════════════════════════════════════════ */
  .hero-marquee {
    position: relative; z-index: 1;
    border-top: 1px solid rgba(255,255,255,.08);
    background: rgba(0,0,0,.22);
    padding: .95rem 0;
  }
  .hero-marquee .marquee-set { gap: var(--space-8, 2.5rem); padding-right: var(--space-8, 2.5rem); }
  .marquee-item {
    display: inline-flex; align-items: center; gap: .6rem;
    font-family: var(--font-mono); font-size: .78rem; letter-spacing: .04em;
    color: rgba(255,255,255,.7); white-space: nowrap;
  }
  .marquee-spark { flex: 0 0 auto; opacity: .9; }

  /* ═══════════════════════════════════════════════════════════
     INTRO — pure-CSS auto-play (JS-independent; ends visible)
  ═══════════════════════════════════════════════════════════ */
  @media (prefers-reduced-motion: no-preference) {
    #hero .hero-headline { animation: hl-wipe .9s cubic-bezier(.16,1,.3,1) .05s both; }
    .hero-eyebrow  { animation: rise .7s cubic-bezier(.16,1,.3,1) .1s both; }
    .hero-sub      { animation: rise .8s cubic-bezier(.16,1,.3,1) .42s both; }
    .hero-ctas     { animation: rise .7s cubic-bezier(.16,1,.3,1) .54s both; }
    .hero-trust    { animation: rise .7s cubic-bezier(.16,1,.3,1) .62s both; }
    .hero-support  { animation: rise .7s cubic-bezier(.16,1,.3,1) .72s both; }
    .video-frame   { animation: frame-in 1s cubic-bezier(.16,1,.3,1) .2s both; }
    .floating-card { animation: card-in .8s cubic-bezier(.16,1,.3,1) 1.05s both, card-float 6s ease-in-out 1.9s infinite; }
    .connector-path { animation: draw-arrow 1.1s cubic-bezier(.5,0,.2,1) 1.3s both; }
  }
  @keyframes hl-wipe { from { clip-path: inset(0 0 102% 0); } to { clip-path: inset(0 0 -12% 0); } }
  @keyframes rise   { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes frame-in { from { opacity: 0; transform: scale(.94) translateY(16px); } to { opacity: 1; transform: scale(1) translateY(0); } }
  @keyframes card-in { from { opacity: 0; transform: translateY(18px) scale(.92); } to { opacity: 1; transform: translateY(0) scale(1); } }
  @keyframes card-float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }
  @keyframes draw-arrow { from { opacity: 0; stroke-dashoffset: 140; } to { opacity: 1; stroke-dashoffset: 0; } }

  /* ═══════════════════════════════════════════════════════════
     RESPONSIVE
  ═══════════════════════════════════════════════════════════ */
  @media (max-width: 1100px) {
    #hero .hero-inner { grid-template-columns: minmax(0, 1fr) minmax(0, .82fr); gap: 2.2rem; }
    .floating-card { max-width: 200px; padding: .85rem 1rem; }
  }
  @media (max-width: 900px) {
    .hero-wrap { padding-top: calc(var(--nav-h, 72px) + clamp(1.8rem, 5vh, 2.6rem)); }
    #hero .hero-inner { grid-template-columns: minmax(0, 1fr); gap: 2.6rem; }
    .hero-text { max-width: 620px; min-width: 0; }
    .hero-visual { order: 2; max-width: 380px; margin-top: .5rem; }
    .connector-arrow { display: none; }
    .floating-card { left: 4%; bottom: -6%; }
    #hero .hero-headline br { display: none; }
  }
  @media (max-width: 560px) {
    #hero .hero-headline { font-size: clamp(2.1rem, 8.6vw, 2.8rem); letter-spacing: -.04em; }
    .hero-ctas .btn, .btn-hero-ghost { width: 100%; max-width: 320px; }
    .floating-card { position: static; margin: 1.3rem auto 0; max-width: 280px; }
    .video-frame { border-radius: 24px 24px 34% 24px; }
    .hero-marquee { padding: .8rem 0; }
    .marquee-item { font-size: .72rem; }
  }

  /* ── Reduced motion: static, fully visible ──────────────── */
  @media (prefers-reduced-motion: reduce) {
    .bg-aurora, .eyebrow-dot, .hero-ctas .btn-amber::after,
    .floating-card, .video-frame, .connector-path { animation: none !important; }
    #hero .hero-headline { clip-path: none !important; }
    #hero .hero-text > *, .video-frame, .floating-card, .connector-path { opacity: 1 !important; }
    .marquee-track { animation-play-state: paused; }
  }
</style>

<!-- ═══════════════════════════════════════════════════════════
     Motion island — bundled (vanilla TS + GSAP + Lenis).
     Desktop fine-pointer + not-reduced only. Content never
     depends on this script (intro + marquee are pure CSS).
═══════════════════════════════════════════════════════════ -->
<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import Lenis from 'lenis';

  const hero = document.getElementById('hero');

  if (hero) {
    const fine   = window.matchMedia('(pointer: fine) and (min-width: 901px)');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');
    if (fine.matches && !reduce.matches) {
      const start = () => initMotion(hero);
      'requestIdleCallback' in window
        ? (window as any).requestIdleCallback(start, { timeout: 600 })
        : setTimeout(start, 200);
    }
  }

  function initMotion(hero: HTMLElement) {
    gsap.registerPlugin(ScrollTrigger);

    const visual = hero.querySelector<HTMLElement>('.visual-scroll');
    const frame  = hero.querySelector<HTMLElement>('.video-frame');
    const video  = hero.querySelector<HTMLElement>('.video-el');
    const text   = hero.querySelector<HTMLElement>('.hero-text');
    if (!visual || !frame) return;

    /* ── Lenis smooth-scroll (global, lightweight, removable) ── */
    const lenis = new Lenis({ lerp: 0.1, smoothWheel: true });
    lenis.on('scroll', ScrollTrigger.update);
    gsap.ticker.add((t) => lenis.raf(t * 1000));
    gsap.ticker.lagSmoothing(0);

    /* ── Scroll choreography: gentle parallax recede + Ken Burns ── */
    gsap.timeline({ scrollTrigger: { trigger: hero, start: 'top top', end: 'bottom top', scrub: 1 } })
      .fromTo(visual, { y: 0 }, { y: -60, ease: 'none' }, 0)
      .to(text,   { y: -30, autoAlpha: .55, ease: 'power1.in' }, 0.35)
      .to(visual, { autoAlpha: .5, ease: 'power1.in' }, 0.45);

    if (video) {
      gsap.to(video, { scale: 1.16, ease: 'none', scrollTrigger: { trigger: hero, start: 'top top', end: 'bottom top', scrub: 1 } });
    }

    /* ── Cursor parallax tilt on the video panel ── */
    let tx = 0, ty = 0, rx = 0, ry = 0, raf = 0;
    const onMove = (e: PointerEvent) => {
      const rect = visual.getBoundingClientRect();
      tx = ((e.clientX - rect.left) / rect.width  - 0.5) * 2;
      ty = ((e.clientY - rect.top)  / rect.height - 0.5) * 2;
    };
    const tick = () => {
      rx += (tx * 4 - rx) * 0.06;
      ry += (-ty * 3 - ry) * 0.06;
      frame.style.transform = `rotateY(${rx.toFixed(2)}deg) rotateX(${ry.toFixed(2)}deg)`;
      raf = requestAnimationFrame(tick);
    };
    hero.addEventListener('pointermove', onMove, { passive: true });
    frame.style.transformStyle = 'preserve-3d';
    (hero.querySelector('.hero-inner') as HTMLElement).style.perspective = '1200px';
    raf = requestAnimationFrame(tick);

    window.addEventListener('pagehide', () => {
      cancelAnimationFrame(raf);
      hero.removeEventListener('pointermove', onMove);
      ScrollTrigger.getAll().forEach((s) => s.kill());
      lenis.destroy();
    }, { once: true });
  }
</script>
