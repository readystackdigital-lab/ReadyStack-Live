/* ── Cinematic element entrance ──────────────────────────── */
@keyframes hero-rise {
  from {
    opacity: 0;
    transform: translateY(22px);
    filter: blur(5px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }
}

/* Stagger: each text block rises in sequence */
#hero .hero-eyebrow   { animation: hero-rise .82s cubic-bezier(.16,1,.3,1) .18s both; }
#hero .hero-headline  { animation: hero-rise .90s cubic-bezier(.16,1,.3,1) .34s both; }
#hero .hero-sub       { animation: hero-rise .90s cubic-bezier(.16,1,.3,1) .50s both; }
#hero .hero-ctas      { animation: hero-rise .82s cubic-bezier(.16,1,.3,1) .65s both; }
#hero .hero-book-link { animation: hero-rise .82s cubic-bezier(.16,1,.3,1) .78s both; }
#hero .hero-proof     { animation: hero-rise .82s cubic-bezier(.16,1,.3,1) .89s both; }
#hero .hero-trust     { animation: hero-rise .82s cubic-bezier(.16,1,.3,1) .98s both; }

