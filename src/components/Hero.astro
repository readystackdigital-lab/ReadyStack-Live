---
---

<section id="hero" aria-label="Hero — secure digital foundations for Australian small businesses, built and managed by ReadyStack Digital in Sydney">
  <video class="hero-video" autoplay loop muted playsinline poster="/assets/images/hero-dashboard.png">
    <source src="/assets/videos/hero-video.mp4" type="video/mp4" />
  </video>
  <div class="hero-video-overlay" aria-hidden="true"></div>
  <canvas id="hero-particles" aria-hidden="true"></canvas>

  <div class="hero-live-strip" aria-label="Current date and time">
    <span id="live-date">--</span>
    <span class="live-separator">•</span>
    <span id="live-time">--:--</span>
  </div>

  <div class="hero-inner">

    <!-- Left: headline & CTA -->
    <div class="hero-text">
      <div class="hero-eyebrow">
        <span class="eyebrow-pill">
          <span class="eyebrow-dot" aria-hidden="true"></span>
          Sydney-based · Australia-wide delivery
        </span>
        <span class="eyebrow-pill eyebrow-pill-ghost">Website · Microsoft 365 · Email Security · Essential Eight</span>
      </div>

      <h1 class="hero-headline">
        Secure digital foundations<br>
        <span class="headline-amber">for Australian small businesses</span> —<br>
        <span class="headline-outline">built and managed properly.</span>
      </h1>

      <p class="hero-sub">
        ReadyStack Digital builds and manages websites, Microsoft 365, email security, and Essential Eight alignment for Australian small businesses — set up properly from day one, with ongoing monthly care so your digital foundations keep working while you run your business.
      </p>

      <div class="hero-ctas">
        <a href="#contact" class="btn btn-amber btn-lg magnetic">
          <span>Get a Quote</span>
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M3 9h12M9 3l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="#pricing" class="btn btn-ghost btn-lg">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.5"/>
            <path d="M7 6.5l4 2.5-4 2.5V6.5z" fill="currentColor"/>
          </svg>
          <span>View Packages</span>
        </a>
      </div>

      <div class="hero-proof">
        <div class="proof-item">
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path d="M2 7.5l4 4 7-7" stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          SEO-ready from launch
        </div>
        <div class="proof-item">
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path d="M2 7.5l4 4 7-7" stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Microsoft 365 + MFA setup
        </div>
        <div class="proof-item">
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path d="M2 7.5l4 4 7-7" stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          SPF · DKIM · DMARC configured
        </div>
        <div class="proof-item">
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path d="M2 7.5l4 4 7-7" stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Essential Eight ML1 alignment
        </div>
        <div class="proof-item">
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path d="M2 7.5l4 4 7-7" stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Monthly managed care
        </div>
      </div>

      <p class="hero-trust">Websites from $1,000. Online Presence + M365 from $1,750. Secure SMB Foundation from $4,000. Managed care from $100/month.</p>
    </div>

  </div><!-- /hero-inner -->

  <div class="scroll-nudge" aria-hidden="true">
    <div class="scroll-line-wrap"><div class="scroll-line-inner"></div></div>
    <span>Scroll</span>
  </div>
</section>
