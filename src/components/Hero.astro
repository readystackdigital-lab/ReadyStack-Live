---
/*
  ──────────────────────────────────────────────────────────────
  ReadyStack Digital — Homepage Hero · "3D Tilt Panel"  (v2)
  ──────────────────────────────────────────────────────────────
  Reference-inspired (Dribbble crypto-payments shot) reinterpreted in
  ReadyStack's brand: the whole hero composition sits on a real CSS
  3D-perspective panel that tilts with cursor + scroll, with glossy
  gradient ORBS popping at different depths (translateZ on a
  preserve-3d plane). Bold oversized type, rounded floating panel,
  amber/charcoal gradient-mesh background.

  Brand: amber (--accent) + charcoal. ACCENT IS A VARIABLE — flip the
  two --accent vars below to electric blue (#2563EB / #60A5FA) to match
  the reference palette in one change.

  Stack: Astro static. Vanilla TS + GSAP + Lenis in a bundled <script>.
  Content (h1/subhead/CTAs/eyebrow/AI badge/trust + proof/book link) is
  server-rendered, crawlable, JS-independent. Orbs are aria-hidden.
*/
---

<section id="hero" aria-label="Hero: ReadyStack Digital website, domain, email, SEO and care">

  <!-- Background: video + gradient mesh + faint grain (flat, behind the 3D plane) -->
  <div class="hero-bg" aria-hidden="true">
    <video
      class="hero-video-bg"
      src="/assets/video/hero-video.mp4"
      autoplay
      loop
      muted
      playsinline
      preload="none"
    ></video>
    <div class="bg-mesh"></div>
    <div class="bg-grain"></div>
  </div>

  <!-- 3D perspective context -->
  <div class="hero-3d">
    <!-- scroll-driven tilt wrapper -->
    <div class="hero-scroll">
      <!-- cursor-driven tilt panel (preserve-3d holds the orbs at depth) -->
      <div class="hero-panel">

        <!-- ── Glossy 3D orbs (decorative, depth via translateZ) ── -->
        <div class="orbs" aria-hidden="true">
          <span class="orb orb--amber"  style="--z:110px"></span>
          <span class="orb orb--dark"   style="--z:-70px"></span>
          <span class="orb orb--chrome" style="--z:-40px"></span>
          <span class="orb orb--ring"   style="--z:70px"></span>
          <span class="orb orb--mini"   style="--z:150px"></span>
        </div>

        <!-- ══════════════════════════════════════════════════════
             CONTENT — real, crawlable, JS-independent HTML
        ══════════════════════════════════════════════════════ -->
        <div class="hero-inner">
          <div class="hero-text">
            <div class="hero-eyebrow">
              <span class="eyebrow-pill">
                <span class="eyebrow-dot" aria-hidden="true"></span>
                Website • Email • SEO • Care • Social • AI Agent
              </span>
              <span class="eyebrow-pill eyebrow-pill-ghost">Nationwide online presence support</span>
            </div>

            <h1 class="hero-headline">
              Your website, email, SEO, and social content,<br>
              <span class="headline-amber">built, managed, and kept visible</span><br>
              <span class="headline-outline">without the stress.</span>
            </h1>

            <p class="hero-sub">
              ReadyStack Digital helps small businesses build a professional online presence: websites, business email, AI Agent, SEO, and secure monthly care, plus branded social media content that keeps your brand active and visible.
            </p>

            <div class="hero-ctas">
              <a href="/contact" class="btn btn-amber btn-lg magnetic">
                <span>Get a Quote</span>
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                  <path d="M3 9h12M9 3l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
              <a href="/packages" class="btn btn-hero-ghost btn-lg">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                  <circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M7 6.5l4 2.5-4 2.5V6.5z" fill="currentColor"/>
                </svg>
                <span>View Packages</span>
              </a>
            </div>

            <a href="#ai-agent" class="hero-ai-badge">
              <span class="hero-ai-spark" aria-hidden="true">✦</span>
              <span class="hero-ai-label"><strong>New: AI Agent &amp; Reception</strong></span>
              <span class="hero-ai-price">from $1,500 setup + $600/mo</span>
            </a>

            <p class="hero-trust">Websites from $1,000. Managed care from $100/month.</p>

            <div class="hero-support">
              <div class="hero-book-link">
                <svg width="13" height="13" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                  <path d="M3.75 3.75h2.625L7.5 6.563 6.094 7.406a8.25 8.25 0 0 0 4.5 4.5L11.438 10.5l2.813 1.125-.75 2.625a1.125 1.125 0 0 1-1.125 1.125A11.25 11.25 0 0 1 2.625 4.875 1.125 1.125 0 0 1 3.75 3.75z" stroke="currentColor" stroke-width="1.3" fill="none"/>
                </svg>
                Prefer to talk first?&nbsp;<a href="/contact#book" class="hero-book-link__anchor">Book a free 30-min strategy call</a>, no commitment
              </div>

              <div class="hero-proof">
                <span class="proof-item"><svg width="14" height="14" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path d="M2 7.5l4 4 7-7" stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>SEO-ready websites</span>
                <span class="proof-item"><svg width="14" height="14" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path d="M2 7.5l4 4 7-7" stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Professional email options</span>
                <span class="proof-item"><svg width="14" height="14" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path d="M2 7.5l4 4 7-7" stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Secure hosting setup</span>
                <span class="proof-item"><svg width="14" height="14" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path d="M2 7.5l4 4 7-7" stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Domain and DNS managed</span>
                <span class="proof-item"><svg width="14" height="14" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path d="M2 7.5l4 4 7-7" stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Monthly website care</span>
                <span class="proof-item"><svg width="14" height="14" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path d="M2 7.5l4 4 7-7" stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Social &amp; blog content</span>
                <span class="proof-item"><svg width="14" height="14" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path d="M2 7.5l4 4 7-7" stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>24/7 AI agent &amp; reception</span>
              </div>
            </div>
          </div><!-- /hero-text -->
        </div><!-- /hero-inner -->
      </div><!-- /hero-panel -->
    </div><!-- /hero-scroll -->
  </div><!-- /hero-3d -->

  <div class="scroll-nudge" aria-hidden="true">
    <div class="scroll-line-wrap"><div class="scroll-line-inner"></div></div>
    <span>Scroll</span>
  </div>
</section>

<style is:global>
  html.lenis, html.lenis body { height: auto; }
  .lenis.lenis-smooth { scroll-behavior: auto !important; }
  .lenis.lenis-smooth [data-lenis-prevent] { overscroll-behavior: contain; }
  .lenis.lenis-stopped { overflow: clip; }
  .lenis.lenis-smooth iframe { pointer-events: none; }
</style>

<style>
  /* ═══════════════════════════════════════════════════════════
     SHELL + palette (flip --accent vars to blue to match the ref)
  ═══════════════════════════════════════════════════════════ */
  #hero {
    --accent: var(--amber, #F59E0B);
    --accent-2: var(--amber-300, #FCD34D);
    --ink: #0b0d11;
    --panel: rgba(255,255,255,.038);
    position: relative;
    /* override stale global `#hero` rules (display:flex + padding-top)
       that shrank the 3D stack and double-padded the content */
    display: block;
    padding: 0;
    min-height: clamp(660px, 94svh, 900px);
    overflow: hidden;
    isolation: isolate;
    background:
      radial-gradient(120% 90% at 78% 12%, rgba(245,158,11,.16), transparent 50%),
      radial-gradient(90% 80% at 10% 100%, rgba(245,158,11,.06), transparent 60%),
      linear-gradient(160deg, #15171d 0%, #0d0f13 55%, #0a0c0f 100%);
  }

  /* ── Background video + mesh + grain (flat, behind the 3D plane) ──── */
  .hero-bg { position: absolute; inset: 0; z-index: 0; pointer-events: none; }

  /* Looping blurred video — sits at the very bottom of .hero-bg */
  .hero-video-bg {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    /* scale past edges so blur doesn't expose transparent fringe */
    transform: scale(1.06);
    transform-origin: center center;
    /* light blur + darken to blend with the dark amber theme */
    filter: blur(6px) brightness(0.3);
    pointer-events: none;
  }

  .bg-mesh {
    position: absolute; inset: -10%;
    background:
      radial-gradient(38% 50% at 72% 30%, rgba(245,158,11,.18), transparent 70%),
      radial-gradient(30% 40% at 20% 70%, rgba(252,211,77,.07), transparent 70%);
    filter: blur(20px);
  }
  .bg-grain {
    position: absolute; inset: 0; opacity: .14; mix-blend-mode: soft-light;
    background: url('/images/hero/grain.webp') repeat; background-size: 320px 320px;
  }

  /* ═══════════════════════════════════════════════════════════
     3D PERSPECTIVE PLANE
  ═══════════════════════════════════════════════════════════ */
  .hero-3d {
    position: relative; z-index: 1;
    perspective: 1500px;
    perspective-origin: 50% 38%;
    min-height: inherit;
    /* own compositing layer — prevents video filter from collapsing preserve-3d */
    will-change: transform;
  }
  .hero-scroll { transform-style: preserve-3d; min-height: inherit; }
  .hero-panel {
    position: relative;
    transform-style: preserve-3d;
    width: min(1240px, calc(100% - 56px));
    margin-inline: auto;
    min-height: clamp(600px, 88svh, 820px);
    display: flex; align-items: flex-start;
    padding: clamp(7rem, 13vh, 9.5rem) clamp(1.6rem, 4vw, 4rem) clamp(3.5rem, 6vh, 5rem);
    border-radius: 28px;
    will-change: transform;
    /* JS writes rotateX/rotateY each frame; flat at rest (no JS / reduced) */
  }

  /* ═══════════════════════════════════════════════════════════
     GLOSSY ORBS (depth via translateZ on the preserve-3d plane)
  ═══════════════════════════════════════════════════════════ */
  .orbs { position: absolute; inset: 0; transform-style: preserve-3d; pointer-events: none; }
  .orb {
    position: absolute; border-radius: 50%;
    transform: translateZ(var(--z, 0px));
    will-change: transform;
  }
  .orb--amber {
    top: 9%; right: 5%; width: clamp(120px, 14vw, 210px); aspect-ratio: 1;
    background:
      radial-gradient(circle at 32% 26%, #fff 0%, #ffe6ad 14%, var(--accent) 46%, #8a5600 100%);
    box-shadow: 0 40px 80px rgba(0,0,0,.5), 0 0 60px rgba(245,158,11,.4),
      inset -14px -18px 38px rgba(120,60,0,.55), inset 10px 12px 26px rgba(255,255,255,.45);
    animation: float-a 9s ease-in-out infinite;
  }
  .orb--dark {
    bottom: 12%; left: 6%; width: clamp(90px, 11vw, 160px); aspect-ratio: 1;
    background:
      radial-gradient(circle at 34% 28%, rgba(255,255,255,.55) 0%, rgba(150,160,180,.22) 14%, #1b1f27 48%, #090b0f 100%);
    box-shadow: 0 36px 70px rgba(0,0,0,.6),
      inset -12px -14px 34px rgba(0,0,0,.6), inset 9px 11px 22px rgba(255,255,255,.2);
    animation: float-b 11s ease-in-out infinite;
  }
  .orb--chrome {
    top: 16%; left: 9%; width: clamp(54px, 6vw, 92px); aspect-ratio: 1;
    background:
      radial-gradient(circle at 34% 28%, #fff 0%, #e8ebf2 22%, #b9bfca 55%, #6c7280 100%);
    box-shadow: 0 26px 50px rgba(0,0,0,.5),
      inset -8px -10px 22px rgba(40,44,52,.5), inset 6px 8px 16px rgba(255,255,255,.7);
    animation: float-a 7.5s ease-in-out infinite reverse;
  }
  .orb--ring {
    bottom: 15%; right: 10%; width: clamp(70px, 9vw, 130px); aspect-ratio: 1;
    background: transparent; border: 2px solid rgba(245,158,11,.5);
    box-shadow: 0 0 40px rgba(245,158,11,.25), inset 0 0 24px rgba(245,158,11,.18);
    animation: float-b 8.5s ease-in-out infinite;
  }
  .orb--mini {
    top: 22%; right: 22%; width: clamp(20px, 2.4vw, 34px); aspect-ratio: 1;
    background: radial-gradient(circle at 35% 30%, #fff, var(--accent-2) 40%, var(--accent) 100%);
    box-shadow: 0 0 24px rgba(252,211,77,.6);
    animation: float-a 6s ease-in-out infinite;
  }
  @keyframes float-a { 0%,100%{ translate: 0 0; } 50%{ translate: 0 -16px; } }
  @keyframes float-b { 0%,100%{ translate: 0 0; } 50%{ translate: 0 14px; } }

  /* ═══════════════════════════════════════════════════════════
     CONTENT
  ═══════════════════════════════════════════════════════════ */
  .hero-inner { position: relative; z-index: 2; width: 100%; transform: translateZ(40px); display: flex; justify-content: center; }
  /* Centered editorial column — keeps the composition balanced inside
     the tilting panel with the orbs framing it from the margins. */
  .hero-text { position: relative; max-width: 820px; margin-inline: auto; text-align: center; }

  .hero-eyebrow { display: flex; align-items: center; justify-content: center; flex-wrap: wrap; gap: .55rem; margin-bottom: clamp(1.1rem, 2vw, 1.6rem); }
  .eyebrow-pill { backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); }

  #hero .hero-headline {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 4.5vw, 4.25rem);
    line-height: .98;
    letter-spacing: -0.05em;
    text-wrap: balance;
    color: #fff;
  }
  #hero .headline-amber {
    display: inline-block; line-height: .96; color: var(--accent);
    text-shadow: 0 0 50px rgba(245,158,11,.45), 0 0 110px rgba(245,158,11,.2);
  }
  #hero .headline-outline {
    display: inline-block; line-height: 1; margin-top: .04em;
    color: rgba(255,255,255,.1); -webkit-text-stroke: 1.4px rgba(255,255,255,.6);
  }

  #hero .hero-sub {
    max-width: 620px;
    margin-inline: auto;
    margin-top: clamp(1.1rem, 1.8vw, 1.5rem);
    font-size: clamp(1.02rem, 1.15vw, 1.16rem);
    line-height: 1.68;
    color: rgba(255,255,255,.72);
  }

  .hero-ctas { display: flex; align-items: center; justify-content: center; flex-wrap: wrap; gap: .75rem; margin-top: clamp(1.5rem, 2.4vw, 2rem); }
  .hero-ctas .btn { min-height: 48px; }

  .hero-ai-badge {
    display: inline-flex; align-items: center; flex-wrap: wrap; gap: .5rem;
    margin-top: 1.1rem; padding: .55rem .95rem; border-radius: 999px; text-decoration: none;
    background: linear-gradient(120deg, rgba(245,158,11,.18), rgba(255,255,255,.05));
    border: 1px solid rgba(245,158,11,.42); color: #fff; font-size: .82rem;
    min-height: 40px;
    transition: border-color .2s, transform .2s, background .2s;
  }
  .hero-ai-badge:hover { border-color: var(--accent); transform: translateY(-1px); background: linear-gradient(120deg, rgba(245,158,11,.26), rgba(255,255,255,.06)); }
  .hero-ai-spark { color: var(--accent-2); font-size: .9rem; line-height: 1; animation: hero-ai-twinkle 2.6s ease-in-out infinite; }
  @keyframes hero-ai-twinkle { 0%,100% { opacity:1; transform: scale(1); } 50% { opacity:.55; transform: scale(.82); } }
  .hero-ai-label strong { color: #fff; font-weight: var(--weight-semibold); }
  .hero-ai-price { color: var(--accent-2); font-weight: var(--weight-semibold); }

  .hero-trust { margin-top: 1rem; font-size: .82rem; color: rgba(255,255,255,.6); }

  .hero-support { max-width: 680px; margin: clamp(1.6rem, 2.6vw, 2.1rem) auto 0; padding-top: 1.1rem; border-top: 1px solid rgba(255,255,255,.08); }
  .hero-book-link { display: flex; align-items: center; justify-content: center; gap: .35rem; font-size: .78rem; color: rgba(255,255,255,.6); flex-wrap: wrap; line-height: 1.5; }
  .hero-book-link svg { flex-shrink: 0; color: rgba(255,255,255,.6); }
  .hero-book-link__anchor { color: var(--accent); text-decoration: none; font-weight: 600; }
  .hero-book-link__anchor:hover { text-decoration: underline; text-underline-offset: 3px; }
  .hero-proof { display: flex; align-items: center; justify-content: center; flex-wrap: wrap; gap: .42rem; margin-top: .85rem; }
  .proof-item {
    display: inline-flex; align-items: center; gap: .38rem;
    padding: .3rem .56rem; border: 1px solid rgba(255,255,255,.1); border-radius: 999px;
    background: rgba(255,255,255,.04); color: rgba(255,255,255,.66);
    font-size: .74rem; line-height: 1.2;
    transition: border-color .22s, background .22s, color .22s;
  }
  .proof-item svg { flex: 0 0 auto; }
  .proof-item:hover { border-color: rgba(245,158,11,.32); background: rgba(245,158,11,.07); color: rgba(255,255,255,.88); }

  .btn-hero-ghost {
    display: inline-flex; align-items: center; justify-content: center; gap: .5rem;
    font-family: var(--font-display); font-weight: var(--weight-semibold); font-size: var(--text-md);
    padding: .85rem 1.85rem; min-height: 48px;
    background: rgba(255,255,255,.04); color: rgba(255,255,255,.8);
    border: 1.5px solid rgba(255,255,255,.2); border-radius: var(--radius-full);
    cursor: pointer; text-decoration: none; white-space: nowrap;
    transition: background .18s, color .18s, border-color .18s, transform .18s;
  }
  .btn-hero-ghost:hover { background: rgba(255,255,255,.09); color: #EEEFF2; border-color: rgba(255,255,255,.36); transform: translateY(-1px); }
  .btn-hero-ghost:active { transform: scale(.97); }

  .hero-ctas .btn-amber { position: relative; overflow: hidden; }
  .hero-ctas .btn-amber::after {
    content:''; position: absolute; inset: 0; border-radius: inherit; pointer-events: none;
    background: linear-gradient(108deg, transparent 30%, rgba(255,255,255,.26) 50%, transparent 70%);
    background-size: 200% 100%; animation: btn-gleam 3.4s ease-in-out 2.4s infinite;
  }
  @keyframes btn-gleam { 0%{ background-position:180% center; opacity:0; } 18%{opacity:1;} 82%{opacity:1;} 100%{ background-position:-80% center; opacity:0; } }

  /* ── Scroll nudge ──────────────────────────────────────────── */
  .scroll-nudge {
    position: absolute; bottom: clamp(1rem, 3vh, 1.8rem); left: 50%; translate: -50% 0; z-index: 3;
    display: flex; flex-direction: column; align-items: center; gap: .5rem;
    font-family: var(--font-mono); font-size: .58rem; letter-spacing: .22em; text-transform: uppercase;
    color: rgba(255,255,255,.42);
  }
  .scroll-line-wrap { width: 1px; height: 40px; background: rgba(255,255,255,.14); overflow: hidden; }
  .scroll-line-inner { width: 100%; height: 40%; background: var(--accent); animation: scroll-fall 2.2s cubic-bezier(.76,0,.24,1) infinite; }
  @keyframes scroll-fall { 0%{ transform: translateY(-100%); } 100%{ transform: translateY(250%); } }

  /* ═══════════════════════════════════════════════════════════
     INTRO — pure-CSS auto-play (JS-independent; always ends visible)
  ═══════════════════════════════════════════════════════════ */
  @media (prefers-reduced-motion: no-preference) {
    #hero .hero-headline { animation: hl-wipe .9s cubic-bezier(.16,1,.3,1) .05s both; }
    .hero-eyebrow  { animation: rise .7s cubic-bezier(.16,1,.3,1) .1s both; }
    .hero-sub      { animation: rise .8s cubic-bezier(.16,1,.3,1) .48s both; }
    .hero-ctas     { animation: rise .7s cubic-bezier(.16,1,.3,1) .6s both; }
    .hero-ai-badge { animation: rise .7s cubic-bezier(.16,1,.3,1) .7s both; }
    .hero-trust    { animation: rise .7s cubic-bezier(.16,1,.3,1) .78s both; }
    .hero-support  { animation: rise .7s cubic-bezier(.16,1,.3,1) .88s both; }
    .orb           { animation-play-state: running; opacity: 0; animation: orb-in 1s cubic-bezier(.16,1,.3,1) both; }
    .orb--amber    { animation: orb-in 1s cubic-bezier(.16,1,.3,1) .3s both, float-a 9s ease-in-out 1.3s infinite; }
    .orb--dark     { animation: orb-in 1s cubic-bezier(.16,1,.3,1) .42s both, float-b 11s ease-in-out 1.42s infinite; }
    .orb--chrome   { animation: orb-in 1s cubic-bezier(.16,1,.3,1) .52s both, float-a 7.5s ease-in-out 1.52s infinite reverse; }
    .orb--ring     { animation: orb-in 1s cubic-bezier(.16,1,.3,1) .6s both, float-b 8.5s ease-in-out 1.6s infinite; }
    .orb--mini     { animation: orb-in 1s cubic-bezier(.16,1,.3,1) .66s both, float-a 6s ease-in-out 1.66s infinite; }
  }
  @keyframes hl-wipe { from { clip-path: inset(0 0 102% 0); } to { clip-path: inset(0 0 -12% 0); } }
  @keyframes rise   { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes orb-in { from { opacity: 0; transform: translateZ(var(--z,0px)) scale(.6); } to { opacity: 1; transform: translateZ(var(--z,0px)) scale(1); } }

  /* ═══════════════════════════════════════════════════════════
     RESPONSIVE — tablet & mobile (flat, no 3D)
  ═══════════════════════════════════════════════════════════ */
  @media (max-width: 1024px) {
    .orb--chrome, .orb--mini { display: none; }
    .hero-panel { padding-right: clamp(1.6rem, 4vw, 3rem); }
  }
  @media (max-width: 768px) {
    #hero { min-height: auto; }
    .hero-3d { perspective: none; }
    .hero-scroll, .hero-panel, .orbs { transform-style: flat; }
    .hero-panel {
      width: min(640px, calc(100% - 36px)); min-height: auto; border-radius: 0;
      padding: clamp(6.5rem, 14vh, 8rem) 0 clamp(3.5rem, 7vh, 4.5rem);
      justify-content: center; text-align: center;
    }
    .hero-inner { transform: none; }
    .hero-text { max-width: 560px; margin-inline: auto; }
    .hero-eyebrow, .hero-ctas, .hero-book-link, .hero-proof { justify-content: center; }
    .hero-sub { margin-inline: auto; }
    #hero .hero-headline br { display: none; }
    /* orbs become quiet background decoration */
    .orbs { opacity: .5; }
    .orb { transform: none !important; }
    .orb--amber { top: 4%; right: -6%; }
    .orb--dark { top: auto; bottom: 2%; right: -8%; }
    .orb--chrome, .orb--mini { display: none; }
    .orb--ring { top: 8%; right: 8%; }
  }
  @media (max-width: 560px) {
    #hero .hero-headline { font-size: clamp(2.3rem, 9.6vw, 3.1rem); letter-spacing: -.045em; }
    .hero-ctas .btn, .btn-hero-ghost { width: 100%; max-width: 320px; }
    .scroll-nudge { display: none; }
  }
  @media (max-width: 430px) { .eyebrow-pill-ghost { display: none; } }

  /* ── Reduced motion: flat, static, simple visibility ──────── */
  @media (prefers-reduced-motion: reduce) {
    .orb, .scroll-line-inner, .hero-ai-spark, .hero-ctas .btn-amber::after { animation: none !important; }
    .hero-3d { perspective: none; }
    .hero-scroll, .hero-panel { transform: none !important; }
    #hero .hero-headline { clip-path: none !important; }
    #hero .hero-text > *, .orb { opacity: 1 !important; }
    /* pause/hide the background video for users who prefer no motion */
    .hero-video-bg { display: none; }
  }
</style>

<!-- ═══════════════════════════════════════════════════════════
     Motion island — bundled (vanilla TS + GSAP + Lenis).
     Desktop fine-pointer + not-reduced only. Content never depends
     on this script (intro is pure CSS; panel is flat at rest).
═══════════════════════════════════════════════════════════ -->
<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import Lenis from 'lenis';

  const hero = document.getElementById('hero');

  if (hero) {
    const fine   = window.matchMedia('(pointer: fine) and (min-width: 769px)');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');
    if (fine.matches && !reduce.matches) {
      const start = () => initMotion(hero);
      'requestIdleCallback' in window
        ? (window as any).requestIdleCallback(start, { timeout: 600 })
        : setTimeout(start, 200);
    }
  }

  function initMotion(hero: HTMLElement) {
    gsap.registerPlugin(ScrollTrigger);

    const panel  = hero.querySelector<HTMLElement>('.hero-panel');
    const scroll = hero.querySelector<HTMLElement>('.hero-scroll');
    const orbs   = Array.from(hero.querySelectorAll<HTMLElement>('.orb'));
    if (!panel || !scroll) return;

    /* ── Lenis smooth-scroll (global, lightweight, removable) ── */
    const lenis = new Lenis({ lerp: 0.1, smoothWheel: true });
    lenis.on('scroll', ScrollTrigger.update);
    gsap.ticker.add((t) => lenis.raf(t * 1000));
    gsap.ticker.lagSmoothing(0);

    /* ── Scroll choreography: panel tilts back & recedes, hands off ── */
    gsap.timeline({ scrollTrigger: { trigger: hero, start: 'top top', end: 'bottom top', scrub: 1 } })
      .fromTo(scroll, { rotateX: 0, y: 0 }, { rotateX: -14, y: -60, ease: 'none' }, 0)
      .to(panel, { autoAlpha: 0.55, ease: 'power1.in' }, 0.55)
      .to('.orbs', { autoAlpha: 0, z: 240, ease: 'power1.in' }, 0.5);

    /* ── Cursor-driven 3D tilt of the panel (rAF lerp-smoothed) ── */
    let tx = 0, ty = 0, rx = 0, ry = 0, raf = 0;
    const onMove = (e: PointerEvent) => {
      tx = (e.clientX / window.innerWidth  - 0.5) * 2;
      ty = (e.clientY / window.innerHeight - 0.5) * 2;
    };
    const tick = () => {
      ry += (tx * 9 - ry) * 0.06;     // rotateY from horizontal cursor
      rx += (-ty * 6 - rx) * 0.06;    // rotateX from vertical cursor
      panel.style.transform = `rotateX(${rx.toFixed(2)}deg) rotateY(${ry.toFixed(2)}deg)`;
      // subtle counter-parallax on orbs for extra depth
      for (const o of orbs) {
        const z = o.style.getPropertyValue('--z');
        const depth = parseFloat(z) / 200 || 0.3;
        o.style.transform = `translateZ(${z || '0px'}) translate3d(${(tx * depth * 14).toFixed(1)}px, ${(ty * depth * 10).toFixed(1)}px, 0)`;
      }
      raf = requestAnimationFrame(tick);
    };
    window.addEventListener('pointermove', onMove, { passive: true });
    raf = requestAnimationFrame(tick);

    window.setTimeout(() => { panel.style.willChange = 'auto'; }, 2200);

    window.addEventListener('pagehide', () => {
      cancelAnimationFrame(raf);
      window.removeEventListener('pointermove', onMove);
      ScrollTrigger.getAll().forEach((s) => s.kill());
      lenis.destroy();
    }, { once: true });
  }
</script>
