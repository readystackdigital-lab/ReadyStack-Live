<section id="hero" aria-label="Hero: ReadyStack Digital website, domain, email, SEO and care">
  <video class="hero-video" autoplay loop muted playsinline preload="metadata" poster="/assets/images/hero-dashboard.png" aria-hidden="true">
    <source src="/assets/video/hero-video1.mp4" type="video/mp4" />
  </video>
  <div class="hero-video-overlay" aria-hidden="true"></div>

  <!-- Animated aurora blobs -->
  <div class="hero-aurora" aria-hidden="true">
    <div class="aurora-blob aurora-b1"></div>
    <div class="aurora-blob aurora-b2"></div>
    <div class="aurora-blob aurora-b3"></div>
    <div class="aurora-blob aurora-b4"></div>
  </div>

  <!-- Subtle grid mesh for peripheral depth -->
  <div class="hero-grid" aria-hidden="true"></div>

  <canvas id="hero-particles" aria-hidden="true"></canvas>

  <div class="hero-inner">

    <!-- ── LEFT: text content ──────────────────────────── -->
    <div class="hero-text">
      <div class="hero-eyebrow">
        <span class="eyebrow-pill">
          <span class="eyebrow-dot" aria-hidden="true"></span>
          Website • Email • SEO • Care • Social • AI Agent
        </span>
        <span class="eyebrow-pill eyebrow-pill-ghost">Nationwide online presence support</span>
      </div>

      <h1 class="hero-headline">
        Your website, email, SEO, and social content,<br>
        <span class="headline-amber">built, managed, and kept visible</span><br>
        <span class="headline-outline">without the stress.</span>
      </h1>

      <p class="hero-sub">
        ReadyStack Digital helps small businesses build a professional online presence: websites, business email, AI Agent, SEO, and secure monthly care, plus branded social media content that keeps your brand active and visible.
      </p>

      <div class="hero-ctas">
        <a href="/contact" class="btn btn-amber btn-lg magnetic">
          <span>Get a Quote</span>
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M3 9h12M9 3l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/packages" class="btn btn-hero-ghost btn-lg">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.5"/>
            <path d="M7 6.5l4 2.5-4 2.5V6.5z" fill="currentColor"/>
          </svg>
          <span>View Packages</span>
        </a>
      </div>

      <a href="#ai-agent" class="hero-ai-badge">
        <span class="hero-ai-spark" aria-hidden="true">✦</span>
        <span class="hero-ai-label"><strong>New — AI Agent &amp; Reception</strong></span>
        <span class="hero-ai-price">from $1,500 setup + $600/mo</span>
      </a>

      <div class="hero-book-link">
        <svg width="13" height="13" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M3.75 3.75h2.625L7.5 6.563 6.094 7.406a8.25 8.25 0 0 0 4.5 4.5L11.438 10.5l2.813 1.125-.75 2.625a1.125 1.125 0 0 1-1.125 1.125A11.25 11.25 0 0 1 2.625 4.875 1.125 1.125 0 0 1 3.75 3.75z" stroke="currentColor" stroke-width="1.3" fill="none"/>
        </svg>
        Prefer to talk first?&nbsp;<a href="/contact#book" class="hero-book-link__anchor">Book a free 30-min strategy call</a>, no commitment
      </div>

      <div class="hero-proof">
        <div class="proof-item">
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path d="M2 7.5l4 4 7-7" stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          SEO-ready websites
        </div>
        <div class="proof-item">
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path d="M2 7.5l4 4 7-7" stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Professional email options
        </div>
        <div class="proof-item">
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path d="M2 7.5l4 4 7-7" stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Secure hosting setup
        </div>
        <div class="proof-item">
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path d="M2 7.5l4 4 7-7" stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Domain and DNS managed
        </div>
        <div class="proof-item">
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path d="M2 7.5l4 4 7-7" stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Monthly website care
        </div>
        <div class="proof-item">
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path d="M2 7.5l4 4 7-7" stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Social &amp; blog content
        </div>
        <div class="proof-item">
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path d="M2 7.5l4 4 7-7" stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          24/7 AI agent &amp; reception
        </div>
      </div>

      <p class="hero-trust">Websites from $1,000. Managed care from $100/month.</p>
    </div><!-- /hero-text -->

    <!-- ── RIGHT: 3D visual column ────────────────────── -->
    <div class="hero-visual" aria-hidden="true">

      <!--
        Three.js WebGL globe — amber wireframe sphere with Fibonacci-distributed
        surface dots and cursor-reactive tilt.

        TO USE A SPLINE SCENE INSTEAD:
        1. Browse app.spline.design/discover, pick a scene
        2. Export → Public URL → copy the scene.splinecode URL
        3. Replace the <canvas id="hero-globe"> block with:
              <spline-viewer
                url="https://prod.spline.design/YOUR_ID/scene.splinecode"
                events-target="global"
              ></spline-viewer>
        4. Add to <head> (BaseLayout.astro):
              <script type="module" src="https://unpkg.com/@splinetool/viewer@1.12.95/build/spline-viewer.js" is:inline></script>
      -->
      <canvas id="hero-globe"></canvas>

      <!-- Live date / time badge -->
      <div class="hero-live-badge" aria-label="Current date and time">
        <span class="live-badge-dot" aria-hidden="true"></span>
        <span id="live-date">--</span>
        <span class="live-sep" aria-hidden="true">•</span>
        <span id="live-time">--:--</span>
      </div>
    </div><!-- /hero-visual -->

  </div><!-- /hero-inner -->

  <div class="scroll-nudge" aria-hidden="true">
    <div class="scroll-line-wrap"><div class="scroll-line-inner"></div></div>
    <span>Scroll</span>
  </div>
</section>

<!-- Three.js globe — desktop-only dynamic import with reduced-motion guard -->
<script type="module" is:inline>
(function () {
  const canvas = document.getElementById('hero-globe');
  const visual = canvas?.closest('.hero-visual');

  // Live date/time badge is populated by main.js (initHeroDateTime),
  // which also drives the dashboard clock — keep a single source of truth.

  if (!canvas || !visual) return;

  const isMobile    = window.matchMedia('(max-width: 900px)').matches;
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (isMobile || reduceMotion) { visual.classList.add('hero-visual--static'); return; }

  async function initGlobe() {
    let THREE;
    try {
      THREE = await import('https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.module.min.js');
    } catch (err) {
      console.warn('ReadyStack hero globe failed to load:', err);
      visual.classList.add('hero-visual--static');
      return;
    }

    const width  = Math.max(visual.clientWidth, 320);
    const height = Math.max(visual.clientHeight, 360);

    const renderer = new THREE.WebGLRenderer({
      canvas, antialias: true, alpha: true, powerPreference: 'high-performance'
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 1.75));
    renderer.setClearColor(0x000000, 0);
    renderer.setSize(width, height);
    renderer.outputColorSpace = THREE.SRGBColorSpace;

    const scene  = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(46, width / height, 0.1, 100);
    camera.position.z = 4.75;

    const group      = new THREE.Group();
    const outerGroup = new THREE.Group();
    group.add(outerGroup);
    scene.add(group);

    /* ── Wireframe sphere ──────────────────────────────── */
    const sphereGeo = new THREE.SphereGeometry(1.5, 34, 22);
    const edges     = new THREE.EdgesGeometry(sphereGeo, 3);
    const wireMat   = new THREE.LineBasicMaterial({ color: 0xF59E0B, transparent: true, opacity: 0.20 });
    outerGroup.add(new THREE.LineSegments(edges, wireMat));

    /* ── Inner glow ────────────────────────────────────── */
    const innerGlow = new THREE.Mesh(
      new THREE.SphereGeometry(1.44, 30, 18),
      new THREE.MeshBasicMaterial({ color: 0xF59E0B, transparent: true, opacity: 0.042, side: THREE.BackSide })
    );
    outerGroup.add(innerGlow);

    /* ── Outer atmosphere haze ─────────────────────────── */
    outerGroup.add(new THREE.Mesh(
      new THREE.SphereGeometry(1.82, 24, 16),
      new THREE.MeshBasicMaterial({ color: 0xF59E0B, transparent: true, opacity: 0.022, side: THREE.BackSide })
    ));

    /* ── Rings ─────────────────────────────────────────── */
    const ring = new THREE.Mesh(
      new THREE.TorusGeometry(1.52, 0.007, 6, 160),
      new THREE.MeshBasicMaterial({ color: 0xF59E0B, transparent: true, opacity: 0.58 })
    );
    ring.rotation.x = Math.PI / 2;
    outerGroup.add(ring);

    const ring2 = new THREE.Mesh(
      new THREE.TorusGeometry(1.58, 0.004, 6, 160),
      new THREE.MeshBasicMaterial({ color: 0xFCD34D, transparent: true, opacity: 0.30 })
    );
    ring2.rotation.x = Math.PI / 3.1;
    ring2.rotation.z = Math.PI / 5.8;
    outerGroup.add(ring2);

    const ring3 = new THREE.Mesh(
      new THREE.TorusGeometry(1.64, 0.003, 6, 160),
      new THREE.MeshBasicMaterial({ color: 0xFFFFFF, transparent: true, opacity: 0.12 })
    );
    ring3.rotation.x = Math.PI / 2.55;
    ring3.rotation.y = Math.PI / 4.4;
    outerGroup.add(ring3);

    /* ── Surface dots (Fibonacci distribution) ─────────── */
    const DOT_COUNT   = 112;
    const goldenAngle = Math.PI * (3 - Math.sqrt(5));
    const dotPos      = new Float32Array(DOT_COUNT * 3);
    for (let i = 0; i < DOT_COUNT; i++) {
      const y = 1 - (i / (DOT_COUNT - 1)) * 2;
      const r = Math.sqrt(Math.max(0, 1 - y * y));
      const theta = goldenAngle * i;
      const s = 1.535;
      dotPos[i*3]   = Math.cos(theta) * r * s;
      dotPos[i*3+1] = y * s;
      dotPos[i*3+2] = Math.sin(theta) * r * s;
    }
    const dotGeo = new THREE.BufferGeometry();
    dotGeo.setAttribute('position', new THREE.BufferAttribute(dotPos, 3));
    const dots = new THREE.Points(dotGeo,
      new THREE.PointsMaterial({ color: 0xF59E0B, size: 0.052, transparent: true, opacity: 0.84, sizeAttenuation: true })
    );
    outerGroup.add(dots);

    /* ── Accent dots (white nodes) ─────────────────────── */
    const ACC_COUNT = 20;
    const accPos    = new Float32Array(ACC_COUNT * 3);
    for (let i = 0; i < ACC_COUNT; i++) {
      const phi   = Math.acos(-1 + (2 * i) / ACC_COUNT);
      const theta = Math.sqrt(ACC_COUNT * Math.PI) * phi;
      const s = 1.56;
      accPos[i*3]   = s * Math.sin(phi) * Math.cos(theta);
      accPos[i*3+1] = s * Math.cos(phi);
      accPos[i*3+2] = s * Math.sin(phi) * Math.sin(theta);
    }
    const accGeo = new THREE.BufferGeometry();
    accGeo.setAttribute('position', new THREE.BufferAttribute(accPos, 3));
    const accents = new THREE.Points(accGeo,
      new THREE.PointsMaterial({ color: 0xFFFFFF, size: 0.086, transparent: true, opacity: 0.54, sizeAttenuation: true })
    );
    outerGroup.add(accents);

    /* ── Connection lines ──────────────────────────────── */
    const lineMat = new THREE.LineBasicMaterial({ color: 0xF59E0B, transparent: true, opacity: 0.22 });
    const pairs   = [
      [0,8],[3,14],[7,21],[12,5],[17,28],
      [22,11],[30,4],[25,18],[35,9],[40,2],
      [48,61],[54,33],[70,43],[80,66]
    ];
    const lineGroup = new THREE.Group();
    outerGroup.add(lineGroup);
    pairs.forEach(([a, b]) => {
      if (a >= DOT_COUNT || b >= DOT_COUNT) return;
      const pa = new THREE.Vector3(dotPos[a*3], dotPos[a*3+1], dotPos[a*3+2]);
      const pb = new THREE.Vector3(dotPos[b*3], dotPos[b*3+1], dotPos[b*3+2]);
      lineGroup.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints([pa, pb]), lineMat));
    });

    /* ── Orbiting satellites ───────────────────────────── */
    const SAT_CONFIGS = [
      { angle: 0,            speed:  0.44, incl: 0,            r: 1.70, size: 0.055, color: 0xF59E0B },
      { angle: Math.PI*0.7,  speed: -0.28, incl: Math.PI/4.2,  r: 1.74, size: 0.040, color: 0xFCD34D },
      { angle: Math.PI*1.4,  speed:  0.35, incl: Math.PI/3.0,  r: 1.72, size: 0.044, color: 0xFFFFFF },
    ];
    const satellites = SAT_CONFIGS.map(cfg => {
      const mesh = new THREE.Mesh(
        new THREE.SphereGeometry(cfg.size, 8, 6),
        new THREE.MeshBasicMaterial({ color: cfg.color, transparent: true, opacity: 0.95 })
      );
      outerGroup.add(mesh);
      return { mesh, ...cfg };
    });

    /* ── Data pulses (travel along connection lines) ────── */
    const PULSE_PAIRS = [[0,8],[7,21],[22,11],[48,61]];
    const pulses = PULSE_PAIRS.map((pair, i) => {
      if (pair[0] >= DOT_COUNT || pair[1] >= DOT_COUNT) return null;
      const from = new THREE.Vector3(dotPos[pair[0]*3], dotPos[pair[0]*3+1], dotPos[pair[0]*3+2]);
      const to   = new THREE.Vector3(dotPos[pair[1]*3], dotPos[pair[1]*3+1], dotPos[pair[1]*3+2]);
      const mesh = new THREE.Mesh(
        new THREE.SphereGeometry(0.034, 6, 6),
        new THREE.MeshBasicMaterial({ color: 0xFFFDE8, transparent: true, opacity: 0 })
      );
      outerGroup.add(mesh);
      return { mesh, from, to, progress: i * 0.27, speed: 0.34 + Math.random() * 0.14 };
    }).filter(Boolean);

    /* ── Resize + cursor ───────────────────────────────── */
    let mx = 0, my = 0, tiltX = 0, tiltZ = 0, raf = 0, disposed = false;

    function onResize() {
      if (disposed) return;
      const w = Math.max(visual.clientWidth, 320);
      const h = Math.max(visual.clientHeight, 360);
      renderer.setSize(w, h);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    }
    function onMouseMove(e) {
      mx = (e.clientX / window.innerWidth  - 0.5) * 2;
      my = (e.clientY / window.innerHeight - 0.5) * 2;
    }
    window.addEventListener('resize',    onResize,    { passive: true });
    window.addEventListener('mousemove', onMouseMove, { passive: true });

    /* ── Animation loop ────────────────────────────────── */
    const clock = new THREE.Clock();
    let prevT   = 0;

    function animate() {
      if (disposed) return;
      raf = requestAnimationFrame(animate);
      const t     = clock.getElapsedTime();
      const delta = Math.min(t - prevT, 0.05); // cap spike frames
      prevT = t;

      /* Auto-rotate */
      group.rotation.y = t * 0.095;

      /* Smooth cursor tilt */
      tiltX += (my * 0.20 - tiltX) * 0.045;
      tiltZ += (-mx * 0.11 - tiltZ) * 0.045;
      group.rotation.x = tiltX;
      group.rotation.z = tiltZ;

      /* Subtle inner wobble */
      outerGroup.rotation.y = Math.sin(t * 0.23) * 0.035;

      /* Pulse opacities */
      ring.material.opacity   = 0.44 + Math.sin(t * 1.55) * 0.14;
      ring2.material.opacity  = 0.22 + Math.sin(t * 1.05 + 1) * 0.09;
      ring3.material.opacity  = 0.09 + Math.sin(t * 0.9  + 2) * 0.04;
      dots.material.opacity   = 0.74 + Math.sin(t * 0.80) * 0.10;
      accents.material.opacity= 0.46 + Math.sin(t * 1.20) * 0.08;

      /* Orbit satellites */
      satellites.forEach(sat => {
        sat.angle += sat.speed * delta;
        const x = sat.r * Math.cos(sat.angle);
        const z = sat.r * Math.sin(sat.angle);
        // Tilt orbit plane around X axis by inclination
        sat.mesh.position.set(
          x,
          -z * Math.sin(sat.incl),
           z * Math.cos(sat.incl)
        );
        // Subtle scale pulse to simulate glow
        sat.mesh.scale.setScalar(1 + Math.sin(t * 3.5 + sat.angle) * 0.15);
      });

      /* Data pulses along connection lines */
      pulses.forEach(p => {
        p.progress += p.speed * delta;
        if (p.progress > 1.3) p.progress = -0.3;
        const tp = Math.max(0, Math.min(1, p.progress));
        p.mesh.position.lerpVectors(p.from, p.to, tp);
        // Fade in/out at endpoints
        p.mesh.material.opacity = Math.sin(tp * Math.PI) * 0.96;
      });

      renderer.render(scene, camera);
    }

    /* ── Cleanup ───────────────────────────────────────── */
    function cleanup() {
      disposed = true;
      cancelAnimationFrame(raf);
      window.removeEventListener('resize',    onResize);
      window.removeEventListener('mousemove', onMouseMove);
      [sphereGeo, edges, wireMat, dotGeo, accGeo, lineMat].forEach(r => r?.dispose?.());
      [ring, ring2, ring3, innerGlow].forEach(m => { m.geometry.dispose(); m.material.dispose(); });
      satellites.forEach(s => { s.mesh.geometry.dispose(); s.mesh.material.dispose(); });
      pulses.forEach(p => { p.mesh.geometry.dispose(); p.mesh.material.dispose(); });
      renderer.dispose();
    }
    window.addEventListener('pagehide', cleanup, { once: true });

    onResize();
    animate();
  }

  initGlobe();
})();
</script>

<style>
  /* ──────────────────────────────────────────────────────
     Hero final polish — layout, width, spacing, visual balance
  ────────────────────────────────────────────────────── */

  #hero {
    min-height: clamp(720px, 100svh, 900px);
    overflow: hidden;
    isolation: isolate;
  }

  #hero .hero-inner {
    width: min(1180px, calc(100% - 48px));
    min-height: clamp(680px, 100svh, 860px);
    margin-inline: auto;
    display: grid;
    grid-template-columns: minmax(0, 1.06fr) minmax(410px, 0.94fr);
    align-items: center;
    gap: clamp(2rem, 4vw, 4.75rem);
    padding: clamp(7rem, 11vh, 9rem) 0 clamp(5rem, 8vh, 7rem);
    position: relative;
    z-index: 4;
  }

  #hero .hero-text {
    max-width: 705px;
    align-self: center;
  }

  #hero .hero-eyebrow {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-bottom: clamp(1.2rem, 2.2vw, 1.7rem);
  }

  #hero .eyebrow-pill {
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  #hero .hero-headline {
    max-width: 720px;
    margin: 0;
    font-size: clamp(2.75rem, 3.5vw, 3.5rem);
    line-height: 0.93;
    letter-spacing: -0.058em;
    text-wrap: balance;
  }

  #hero .hero-sub {
    max-width: 650px;
    margin-top: clamp(1.15rem, 2vw, 1.45rem);
    font-size: clamp(1.02rem, 1.18vw, 1.16rem);
    line-height: 1.72;
    color: rgba(255,255,255,.66);
  }

  #hero .hero-ctas {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: clamp(1.65rem, 2.6vw, 2.05rem);
  }

  #hero .hero-ctas .btn {
    min-height: 48px;
  }

  .hero-ai-badge {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.1rem;
    padding: 0.5rem 0.9rem;
    border-radius: 999px;
    text-decoration: none;
    background: linear-gradient(120deg, rgba(245,158,11,0.16), rgba(255,255,255,0.04));
    border: 1px solid rgba(245,158,11,0.4);
    color: #fff;
    font-size: 0.82rem;
    transition: border-color .2s, transform .2s, background .2s;
  }
  .hero-ai-badge:hover { border-color: var(--amber); transform: translateY(-1px); background: linear-gradient(120deg, rgba(245,158,11,0.24), rgba(255,255,255,0.05)); }
  .hero-ai-spark { color: var(--amber-300); font-size: 0.9rem; line-height: 1; animation: hero-ai-twinkle 2.6s ease-in-out infinite; }
  @keyframes hero-ai-twinkle { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: .55; transform: scale(.82); } }
  .hero-ai-label strong { color: #fff; font-weight: var(--weight-semibold); }
  .hero-ai-price { color: var(--amber-300); font-weight: var(--weight-semibold); }

  .hero-book-link {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    max-width: 640px;
    font-size: 0.8125rem;
    color: rgba(255,255,255,.46);
    padding-top: 0.8rem;
    border-top: 1px solid rgba(255,255,255,.07);
    margin-top: 0.85rem;
    flex-wrap: wrap;
    line-height: 1.5;
  }

  .hero-book-link svg {
    flex-shrink: 0;
    color: rgba(255,255,255,.46);
  }

  .hero-book-link__anchor {
    color: #F59E0B;
    text-decoration: none;
    font-weight: 600;
  }

  .hero-book-link__anchor:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  #hero .hero-proof {
    max-width: 690px;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.55rem 0.65rem;
    margin-top: clamp(1.4rem, 2.4vw, 1.9rem);
  }

  #hero .proof-item {
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
    min-height: 32px;
    padding: 0.38rem 0.62rem;
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 999px;
    background: rgba(255,255,255,.035);
    color: rgba(255,255,255,.68);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    line-height: 1.2;
  }

  #hero .proof-item svg {
    flex: 0 0 auto;
  }

  #hero .hero-trust {
    margin-top: 1.05rem;
    color: rgba(255,255,255,.48);
  }

  .btn-hero-ghost {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: .5rem;
