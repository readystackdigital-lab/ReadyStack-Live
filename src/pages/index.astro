---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Outcomes from '../components/Outcomes.astro';
import Steps from '../components/Steps.astro';
import ServicesOverview from '../components/ServicesOverview.astro';
import Security from '../components/Security.astro';
import Pricing from '../components/Pricing.astro';
import CtaBand from '../components/CtaBand.astro';
import Footer from '../components/Footer.astro';
import SiteMotion from '../components/SiteMotion.astro';
---

<BaseLayout>
  <Header />
  <main id="main-content">
    <Hero />
    <Outcomes />
    <Steps />
    <ServicesOverview />
    <Security />
    <Pricing />
    <CtaBand
      heading='Ready to build your <span class="text-amber">online presence?</span>'
      sub="Tell us about your business and we’ll recommend the simplest setup for your website, email, SEO, care and content."
      primaryLabel="Get a Quote"
      primaryHref="/estimate"
      secondaryLabel="Book a Call"
      secondaryHref="/contact#book"
      bookCta={false}
    />
  </main>
  <SiteMotion />
  <Footer />
</BaseLayout>
