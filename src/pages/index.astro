---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import TrustStrip from '../components/TrustStrip.astro';
import About from '../components/About.astro';
import Services from '../components/Services.astro';
import Security from '../components/Security.astro';
import Pricing from '../components/Pricing.astro';
import Presence from '../components/Presence.astro';
import CtaBand from '../components/CtaBand.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Header />
  <main id="main-content">
    <Hero />
    <TrustStrip />
    <About />
    <Services />
    <Security />
    <Pricing />
    <Presence />
    <CtaBand
      heading='Ready to build your <span class="text-amber">online presence?</span>'
      sub="Tell us about your business and we’ll recommend the simplest setup for your website, email, SEO, care and content."
      primaryLabel="Get a Quote"
      primaryHref="/contact"
      secondaryLabel="Book a Call"
      secondaryHref="/contact#book"
      bookCta={false}
    />
  </main>
  <Footer />
</BaseLayout>
