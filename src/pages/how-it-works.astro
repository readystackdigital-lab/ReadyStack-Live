---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import CtaBand from "../components/CtaBand.astro";

const steps = [
  { n: "01", tag: "Step 1", title: "Discovery Call", desc: "A relaxed, no-pressure chat about your business, goals, customers and current online presence.", out: "Goals & fit confirmed" },
  { n: "02", tag: "Step 2", title: "Business Analysis", desc: "We review your services, audience and competitors, then map the right mix of website, SEO and content.", out: "Strategy mapped" },
  { n: "03", tag: "Step 3", title: "Website Setup", desc: "We design and build a fast, mobile-friendly, SEO-ready website that explains your services and drives enquiries.", out: "Website built" },
  { n: "04", tag: "Step 4", title: "Email & SEO Configuration", desc: "We connect your domain, set up professional business email, and configure SEO foundations and Search Console.", out: "Email & SEO live" },
  { n: "05", tag: "Step 5", title: "Social Content Creation", desc: "We plan and create branded content for Instagram, Facebook, TikTok and LinkedIn, plus SEO blog posts.", out: "Content rolling" },
  { n: "06", tag: "Ongoing", title: "Monthly Support & Growth", desc: "We keep everything secure, updated and visible with ongoing care, SEO monitoring and fresh content.", out: "Ongoing growth" },
];

const trust = [
  { v: "Nationwide", l: "Support for small businesses across the whole country" },
  { v: "No lock-in", l: "Stay because it works, not because you’re stuck" },
  { v: "Secure by default", l: "HTTPS, SSL, backups & monitoring as standard" },
  { v: "SEO included", l: "Proper search foundations from day one" },
];
---

<BaseLayout
  title="How It Works: Our Process | ReadyStack Digital"
  description="How ReadyStack Digital works: from discovery call and business analysis to website setup, email & SEO, social content and ongoing monthly support for small businesses."
>
  <Header />
  <main id="main-content">
    <PageHero
      banner="/assets/banners/banner-howitworks-page.jpeg"
      eyebrow="How It Works"
      title='From first call to <span class="text-amber">ongoing growth</span>'
      sub="A clear, proven process that takes your business from idea to a professional online presence, and keeps it growing month after month."
      primaryLabel="Book a Discovery Call"
      primaryHref="/contact"
      secondaryLabel="View Packages"
      secondaryHref="/packages"
    />

    <section class="section" aria-labelledby="process-heading">
      <div class="container">
        <div class="section-head reveal">
          <div class="eyebrow">The Process</div>
          <h2 id="process-heading" class="section-h2">Six steps to a stronger online presence</h2>
          <p class="section-subline">Every step is collaborative: you review and approve as we go. No surprises, no jargon.</p>
        </div>

        <ol class="timeline">
          {steps.map((s, i) => (
            <li class={`tl-step reveal ${i % 2 ? "reveal-delay-1" : ""}`}>
              <div class="tl-node" aria-hidden="true"><span>{s.n}</span></div>
              <div class="tl-card">
                <div class="tl-tag">{s.tag}</div>
                <h3 class="tl-title">{s.title}</h3>
                <p class="tl-desc">{s.desc}</p>
                <div class="tl-out">
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M2.5 8l3.5 3.5 7.5-7.5" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  {s.out}
                </div>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="section section-darker" aria-labelledby="trust-heading">
      <div class="container">
        <div class="section-head reveal">
          <div class="eyebrow eyebrow-light">Why it works</div>
          <h2 id="trust-heading" class="section-h2 section-h2-light">Built on trust, not lock-in</h2>
        </div>
        <div class="trust-grid">
          {trust.map((t, i) => (
            <div class={`trust-card reveal ${i ? `reveal-delay-${i}` : ""}`}>
              <div class="trust-val">{t.v}</div>
              <p class="trust-lbl">{t.l}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CtaBand
      heading='Let’s start with a <span class="text-amber">discovery call.</span>'
      sub="No pressure, no jargon, just a clear conversation about your business and how we can help you grow online."
      primaryLabel="Book a Call"
      primaryHref="/contact"
      secondaryLabel="Get a Quote"
      secondaryHref="/contact"
      bookCta={false}
    />
  </main>
  <Footer />
</BaseLayout>

<style>
  .timeline {
    list-style: none;
    position: relative;
    max-width: 760px;
    margin: 0 auto;
    padding-left: 0;
  }
  .timeline::before {
    content: "";
    position: absolute;
    left: 27px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: linear-gradient(180deg, rgba(245,158,11,.5), rgba(245,158,11,.12));
  }
  .tl-step {
    position: relative;
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: var(--space-5);
    align-items: start;
    padding-bottom: var(--space-8);
  }
  .tl-step:last-child { padding-bottom: 0; }
  .tl-node {
    position: relative;
    z-index: 1;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: var(--weight-bold);
    color: var(--amber-600);
    background: var(--amber-50);
    border: 2px solid rgba(245, 158, 11, 0.4);
    box-shadow: 0 0 0 6px var(--surface);
  }
  .tl-card {
    background: var(--white);
    border: 1px solid var(--charcoal-200);
    border-radius: var(--radius-lg);
    padding: var(--space-5) var(--space-6);
    box-shadow: var(--shadow-sm);
    transition: transform var(--dur-base) var(--ease-out), box-shadow var(--dur-base) var(--ease-out), border-color var(--dur-base) var(--ease-out);
  }
  .tl-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); border-color: rgba(245,158,11,.34); }
  .tl-tag { font-family: var(--font-mono); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: .1em; color: var(--amber-600); margin-bottom: var(--space-2); }
  .tl-title { font-family: var(--font-display); font-size: var(--text-lg); font-weight: var(--weight-bold); color: var(--charcoal-900); letter-spacing: -.02em; }
  .tl-desc { margin-top: var(--space-2); font-size: var(--text-sm); color: var(--charcoal-500); line-height: 1.65; }
  .tl-out { display: inline-flex; align-items: center; gap: .4rem; margin-top: var(--space-3); font-size: var(--text-xs); font-weight: var(--weight-semibold); color: var(--green); background: var(--green-dim); padding: .3rem .65rem; border-radius: 999px; }

  .trust-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-5); }
  .trust-card {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    text-align: center;
    transition: transform var(--dur-base) var(--ease-out), border-color var(--dur-base);
  }
  .trust-card:hover { transform: translateY(-3px); border-color: rgba(245,158,11,.35); }
  .trust-val { font-family: var(--font-display); font-size: var(--text-lg); font-weight: var(--weight-bold); color: var(--amber-300); margin-bottom: var(--space-2); }
  .trust-lbl { font-size: var(--text-sm); color: rgba(255, 255, 255, 0.6); line-height: 1.55; }

  @media (max-width: 820px) { .trust-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 520px) {
    .trust-grid { grid-template-columns: 1fr; }
    .tl-step { grid-template-columns: 44px 1fr; gap: var(--space-4); }
    .tl-node { width: 44px; height: 44px; font-size: .8rem; }
    .timeline::before { left: 21px; }
  }
</style>
