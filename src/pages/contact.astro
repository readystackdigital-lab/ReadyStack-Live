---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import { pricingSummary } from "../data/pricing";

const WHATSAPP_NUMBER = "9779840318084"; // +977 9840318084
const ENDPOINT = "https://agent.readystackdigital.com/enquiry";
const PRICING_SUMMARY = pricingSummary(); // display-ready lines for the branded email
const CAL_EMBED = "https://cal.com/readystack-digital-yyfaab/free-website-strategy-call?embed=true&layout=month_view"; // theme appended in JS to match site theme
const services = [
  "Website Design & Development",
  "Business Email Setup",
  "SEO Services",
  "Website Care & Maintenance",
  "Social Media Content",
  "AI Agent & Reception (24/7 AI receptionist)",
  "Online Store / E-commerce",
  "A full package (website build + monthly care)",
  "Not sure yet, need advice",
];
---

<BaseLayout
  title="Contact: Get a Quote or Book a Call | ReadyStack Digital"
  description="Contact ReadyStack Digital for websites, business email, SEO, care and social media content. Send an enquiry straight to WhatsApp or book a free strategy call. Nationwide support."
>
  <Header />
  <main id="main-content">
    <PageHero
      banner="/assets/banners/banner-contact-page.webp"
      eyebrow="Contact"
      title='Let’s build your <span class="text-amber">online presence</span>'
      sub="Tell us a little about your business and we’ll get straight back to you. Prefer to talk? Book a free, no-pressure strategy call."
      primaryLabel="Book a Free Call"
      primaryHref="#book"
      secondaryLabel="Call us"
      secondaryHref="tel:+61259445135"
      bookCta={false}
    />

    <!-- Enquiry + Book a Call — one card, user picks how to reach us -->
    <section id="book" class="section section-tinted" aria-labelledby="contact-heading">
      <div class="container">
        <h2 id="contact-heading" class="sr-only">Contact ReadyStack Digital</h2>
        <div class="contact-layout">

          <!-- Tabbed card: enquiry form / booking calendar -->
          <div class="contact-card reveal">
            <div class="contact-tabs" role="tablist" aria-label="How would you like to reach us?">
              <button type="button" role="tab" id="tab-enquiry" aria-selected="true" aria-controls="panel-enquiry" class="contact-tab">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="3" stroke="currentColor" stroke-width="1.6"/><path d="M4 7.5l8 6 8-6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Send an enquiry
              </button>
              <button type="button" role="tab" id="tab-book" aria-selected="false" aria-controls="panel-book" class="contact-tab">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="5" width="18" height="16" rx="3" stroke="currentColor" stroke-width="1.6"/><path d="M3 10h18M8 3v4M16 3v4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
                Book a free call
              </button>
            </div>

            <div id="panel-enquiry" role="tabpanel" aria-labelledby="tab-enquiry" tabindex="0">
            <div class="eyebrow">Send an enquiry</div>
            <h3 class="contact-card-title">Tell us what you need</h3>
            <p class="contact-card-sub">Fill this in and we’ll get back to you personally, usually the same business day. You’ll also get our full services &amp; pricing straight to your inbox.</p>

            <form id="wa-form" class="wa-form" novalidate>
              <!-- Honeypot: hidden from humans, tempting to bots -->
              <label class="hp-field" aria-hidden="true">Leave this field empty
                <input type="text" name="company_website" tabindex="-1" autocomplete="off" />
              </label>
              <div class="wa-row">
                <div class="wa-field">
                  <label for="wa-name">Name<span aria-hidden="true">*</span></label>
                  <input type="text" id="wa-name" name="name" required autocomplete="name" placeholder="Your name" />
                </div>
                <div class="wa-field">
                  <label for="wa-business">Business name</label>
                  <input type="text" id="wa-business" name="business" autocomplete="organization" placeholder="Your Business Pty Ltd" />
                </div>
              </div>

              <div class="wa-row">
                <div class="wa-field">
                  <label for="wa-email">Email<span aria-hidden="true">*</span></label>
                  <input type="email" id="wa-email" name="email" required autocomplete="email" placeholder="you@yourbusiness.com.au" />
                </div>
                <div class="wa-field">
                  <label for="wa-phone">Phone</label>
                  <input type="tel" id="wa-phone" name="phone" autocomplete="tel" placeholder="0400 000 000" />
                </div>
              </div>

              <div class="wa-field">
                <label for="wa-service">Service interested in<span aria-hidden="true">*</span></label>
                <select id="wa-service" name="service" required>
                  <option value="" selected disabled>Choose a service…</option>
                  {services.map((s) => <option value={s}>{s}</option>)}
                </select>
              </div>

              <div class="wa-field">
                <label for="wa-message">Message</label>
                <textarea id="wa-message" name="message" rows="4" placeholder="What do you do, who do you serve, and what do you need help with?"></textarea>
              </div>

              <p class="wa-error" id="wa-error" role="alert" hidden></p>

              <p class="wa-ok" id="wa-ok" role="status" hidden>Sent! Check your inbox for our services &amp; pricing. We'll be in touch shortly.</p>

              <div class="wa-ctas">
                <button type="submit" class="btn btn-amber btn-full wa-submit">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="3" stroke="currentColor" stroke-width="1.7"/><path d="M4 7.5l8 6 8-6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <span>Email my enquiry</span>
                </button>

                <a href="#book" class="btn btn-outline btn-full">Book a free strategy call</a>

                <button type="button" class="btn btn-outline btn-full wa-quick" id="wa-instead">
                  <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.04 2C6.58 2 2.14 6.35 2.14 11.7c0 1.92.58 3.7 1.57 5.2L2 22l5.28-1.64a10.1 10.1 0 0 0 4.76 1.2c5.46 0 9.9-4.35 9.9-9.7S17.5 2 12.04 2Zm5.44 11.87c-.24-.12-1.43-.7-1.65-.78-.22-.08-.38-.12-.54.12-.16.23-.62.78-.76.94-.14.16-.28.18-.52.06-.24-.12-1.02-.37-1.95-1.18-.72-.63-1.2-1.42-1.34-1.66-.14-.23-.02-.36.1-.48.11-.1.24-.27.36-.4.12-.14.16-.23.24-.39.08-.16.04-.29-.02-.41-.06-.12-.54-1.28-.74-1.75-.2-.46-.4-.4-.54-.4h-.46c-.16 0-.42.06-.64.29-.22.23-.84.8-.84 1.96 0 1.15.86 2.27.98 2.43.12.16 1.7 2.55 4.12 3.58.58.25 1.03.4 1.38.51.58.18 1.1.16 1.52.1.46-.07 1.43-.57 1.63-1.12.2-.55.2-1.02.14-1.12-.06-.1-.22-.16-.46-.28Z"/></svg>
                  <span>Send via WhatsApp instead</span>
                </button>
              </div>
              <p class="wa-fineprint">We'll email your enquiry back to you with our full services &amp; pricing. No spam, no obligation.</p>
            </form>
            </div>

            <div id="panel-book" role="tabpanel" aria-labelledby="tab-book" tabindex="0" hidden>
              <div class="eyebrow">Book a Call</div>
              <h3 class="contact-card-title">Pick a time that suits you</h3>
              <p class="contact-card-sub">A free 30-minute strategy call, no pitch, just a clear plan for your online presence.</p>
              <div class="cal-embed-wrap">
                <iframe
                  data-src={CAL_EMBED}
                  title="Book a free strategy call with ReadyStack Digital"
                  loading="lazy"
                  class="cal-embed"
                ></iframe>
              </div>
            </div>
          </div>

          <!-- Sidebar: book a call + info -->
          <aside class="contact-aside">
            <div class="info-card book-card reveal">
              <div class="eyebrow eyebrow-light">Prefer to talk?</div>
              <h3 class="info-title">Book a free 30-min strategy call</h3>
              <p class="info-text">A relaxed, no-pressure chat about your business and how we can help you grow online.</p>
              <a href="#book" class="btn btn-amber btn-full">Book a Call</a>
            </div>

            <div class="info-card reveal reveal-delay-1">
              <h3 class="info-title">Business information</h3>
              <ul class="info-list">
                <li>
                  <span class="info-ico" aria-hidden="true"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><polyline points="22,6 12,13 2,6"/></svg></span>
                  <a href="mailto:hello@readystackdigital.com">hello@readystackdigital.com</a>
                </li>
                <li>
                  <span class="info-ico" aria-hidden="true"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg></span>
                  <a href="tel:+61259445135">+61 2 5944 5135</a>
                </li>
                <li>
                  <span class="info-ico" aria-hidden="true"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><polyline points="12,7 12,12 16,14"/></svg></span>
                  <span>Mon–Fri, 9am–5pm</span>
                </li>
              </ul>
            </div>

            <div class="info-card area-card reveal reveal-delay-2">
              <h3 class="info-title">Service area</h3>
              <p class="info-text"><strong class="text-amber">Nationwide.</strong> We support small businesses right across the whole country, remotely and reliably.</p>
            </div>
          </aside>

        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script define:vars={{ WHATSAPP_NUMBER, ENDPOINT, PRICING_SUMMARY }}>
  (function () {
    const form = document.getElementById("wa-form");
    if (!form) return;
    const errorEl = document.getElementById("wa-error");
    const okEl = document.getElementById("wa-ok");
    const submitBtn = form.querySelector(".wa-submit");
    const submitLabel = submitBtn.querySelector("span");

    function val(id) {
      const el = document.getElementById(id);
      return el ? el.value.trim() : "";
    }

    function fields() {
      return {
        name: val("wa-name"),
        business: val("wa-business"),
        email: val("wa-email"),
        phone: val("wa-phone"),
        service: val("wa-service"),
        message: val("wa-message"),
      };
    }

    function validate(f) {
      const missing = [];
      if (!f.name) missing.push("name");
      if (!f.email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(f.email)) missing.push("a valid email");
      if (!f.service) missing.push("a service");
      if (missing.length) {
        errorEl.textContent = "Please add " + missing.join(", ") + " so we can help you properly.";
        errorEl.hidden = false;
        return false;
      }
      errorEl.hidden = true;
      return true;
    }

    // Primary: email the enquiry (branded reply with services & pricing).
    form.addEventListener("submit", async function (e) {
      e.preventDefault();
      const f = fields();
      if (!validate(f)) return;

      submitBtn.disabled = true;
      submitLabel.textContent = "Sending…";
      try {
        const res = await fetch(ENDPOINT, {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({
            ...f,
            company_website: form.elements.company_website.value,
            pricing: PRICING_SUMMARY,
            whatsappUrl: "https://wa.me/" + WHATSAPP_NUMBER,
            pageUrl: window.location.href,
          }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(data.error || "Something went wrong. Please try again.");
        okEl.hidden = false;
        errorEl.hidden = true;
        form.reset();
        submitLabel.textContent = "Email my enquiry";
      } catch (err) {
        errorEl.textContent = err instanceof TypeError
          ? "We couldn't reach the server. Please check your connection or try WhatsApp instead."
          : (err.message || "We couldn't send that just now. Please try WhatsApp instead.");
        errorEl.hidden = false;
        okEl.hidden = true;
        submitLabel.textContent = "Email my enquiry";
      }
      submitBtn.disabled = false;
    });

    // Secondary: open WhatsApp with whatever's filled in.
    document.getElementById("wa-instead").addEventListener("click", function () {
      const f = fields();
      const lines = f.name || f.service || f.message
        ? [
            "New enquiry from the ReadyStack Digital website",
            "",
            f.name ? "Name: " + f.name : null,
            f.business ? "Business: " + f.business : null,
            f.email ? "Email: " + f.email : null,
            f.phone ? "Phone: " + f.phone : null,
            f.service ? "Interested in: " + f.service : null,
            f.message ? "Message: " + f.message : null,
          ].filter(Boolean)
        : ["Hi ReadyStack Digital, I have a quick question about your services."];

      const url =
        "https://wa.me/" + WHATSAPP_NUMBER + "?text=" + encodeURIComponent(lines.join("\n"));
      const win = window.open(url, "_blank", "noopener");
      if (!win) window.location.href = url; // popup-blocked fallback
    });
  })();

  // ─── Contact tabs (enquiry / book a call) ───
  (function () {
    const tabs = { enquiry: document.getElementById("tab-enquiry"), book: document.getElementById("tab-book") };
    const panels = { enquiry: document.getElementById("panel-enquiry"), book: document.getElementById("panel-book") };
    if (!tabs.enquiry || !tabs.book) return;

    function activate(which) {
      for (const key of ["enquiry", "book"]) {
        const on = key === which;
        tabs[key].setAttribute("aria-selected", String(on));
        panels[key].hidden = !on;
      }
      if (which === "book") {
        const iframe = panels.book.querySelector("iframe[data-src]");
        if (iframe) {
          const theme = document.documentElement.getAttribute("data-theme") === "dark" ? "dark" : "light";
          iframe.src = iframe.dataset.src + "&theme=" + theme;
          iframe.removeAttribute("data-src");
        }
      }
    }

    tabs.enquiry.addEventListener("click", () => activate("enquiry"));
    tabs.book.addEventListener("click", () => activate("book"));

    // Any link to #book (hero CTA, sidebar card, form CTA, other pages) opens the booking tab
    document.addEventListener("click", (e) => {
      const a = e.target.closest && e.target.closest('a[href$="#book"]');
      if (a) activate("book");
    });
    window.addEventListener("hashchange", () => {
      if (window.location.hash === "#book") activate("book");
    });
    if (window.location.hash === "#book") activate("book");
  })();
</script>

<style>
  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }

  .contact-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(0, 1fr);
    gap: var(--space-8);
    align-items: start;
  }

  .contact-card {
    background: var(--white);
    border: 1px solid var(--charcoal-200);
    border-radius: var(--radius-xl);
    padding: clamp(1.5rem, 4vw, 2.5rem);
    box-shadow: var(--shadow-md);
  }
  .contact-card-title { font-family: var(--font-display); font-size: var(--text-xl); font-weight: var(--weight-bold); color: var(--charcoal-900); letter-spacing: -.02em; margin: var(--space-1) 0 var(--space-2); }
  .contact-card-sub { font-size: var(--text-sm); color: var(--charcoal-500); line-height: 1.6; margin-bottom: var(--space-6); }

  .wa-form { display: flex; flex-direction: column; gap: var(--space-4); }
  .wa-row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4); }
  .wa-field { display: flex; flex-direction: column; gap: 0.4rem; }
  .wa-field label { font-size: var(--text-sm); font-weight: var(--weight-medium); color: var(--charcoal-700); }
  .wa-field label span { color: var(--amber-600); margin-left: 2px; }
  .wa-field input,
  .wa-field select,
  .wa-field textarea {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--charcoal-900);
    background: var(--charcoal-50);
    border: 1px solid var(--charcoal-200);
    border-radius: var(--radius-md);
    padding: 0.75rem 0.9rem;
    width: 100%;
    transition: border-color var(--dur-fast), box-shadow var(--dur-fast), background var(--dur-fast);
  }
  .wa-field textarea { resize: vertical; min-height: 110px; }
  .wa-field input:focus,
  .wa-field select:focus,
  .wa-field textarea:focus {
    outline: none;
    background: var(--white);
    border-color: var(--amber);
    box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.12);
  }
  .wa-ctas { display: flex; flex-direction: column; gap: var(--space-3); margin-top: var(--space-2); }
  .wa-submit { gap: 0.5rem; }
  .wa-quick { gap: 0.5rem; }
  .wa-error { color: var(--red); font-size: var(--text-sm); background: var(--red-dim); border: 1px solid rgba(239,68,68,.25); border-radius: var(--radius-md); padding: 0.6rem 0.8rem; }
  .wa-ok { color: #16a34a; font-size: var(--text-sm); background: rgba(22,163,74,.08); border: 1px solid rgba(22,163,74,.25); border-radius: var(--radius-md); padding: 0.6rem 0.8rem; }
  .hp-field { position: absolute !important; left: -9999px; width: 1px; height: 1px; overflow: hidden; }
  .wa-fineprint { font-size: var(--text-xs); color: var(--charcoal-400); text-align: center; }

  .contact-aside { display: flex; flex-direction: column; gap: var(--space-5); }
  .info-card {
    background: var(--white);
    border: 1px solid var(--charcoal-200);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    box-shadow: var(--shadow-sm);
  }
  .book-card {
    background: linear-gradient(160deg, #14171d, #0B0D10);
    border-color: rgba(245, 158, 11, 0.28);
    color: #fff;
  }
  .book-card .info-title { color: #fff; }
  .book-card .info-text { color: rgba(255, 255, 255, 0.66); }
  .info-title { font-family: var(--font-display); font-size: var(--text-lg); font-weight: var(--weight-bold); color: var(--charcoal-900); letter-spacing: -.02em; margin-bottom: var(--space-2); }
  .info-text { font-size: var(--text-sm); line-height: 1.65; color: var(--charcoal-500); margin-bottom: var(--space-4); }
  .area-card .info-text { margin-bottom: 0; }
  .info-list { list-style: none; display: flex; flex-direction: column; gap: var(--space-3); }
  .info-list li { display: flex; align-items: center; gap: 0.7rem; font-size: var(--text-sm); color: var(--charcoal-700); }
  .info-list a { color: var(--charcoal-800); text-decoration: none; }
  .info-list a:hover { color: var(--amber-600); }
  .info-ico {
    display: inline-flex; align-items: center; justify-content: center;
    width: 30px; height: 30px; border-radius: 8px;
    background: var(--amber-50); color: var(--amber-600);
    border: 1px solid rgba(245, 158, 11, 0.25);
    flex-shrink: 0;
  }

  /* Tabs: enquiry / book a call */
  .contact-tabs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px;
    background: var(--charcoal-100);
    border: 1px solid var(--charcoal-200);
    border-radius: var(--radius-full);
    padding: 4px;
    margin-bottom: var(--space-6);
  }
  .contact-tab {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    letter-spacing: -.01em;
    color: var(--charcoal-500);
    background: transparent;
    border: 0;
    border-radius: var(--radius-full);
    padding: 0.65rem 1rem;
    cursor: pointer;
    transition: background var(--dur-fast), color var(--dur-fast), box-shadow var(--dur-fast);
  }
  .contact-tab:hover { color: var(--charcoal-800); }
  .contact-tab[aria-selected="true"] {
    background: var(--amber);
    color: var(--charcoal-900);
    box-shadow: 0 2px 10px rgba(245, 158, 11, 0.3);
  }

  /* Cal.com inline embed */
  .cal-embed-wrap {
    border: 1px solid var(--charcoal-200);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--charcoal-50);
  }
  .cal-embed {
    width: 100%;
    height: 680px;
    border: 0;
    display: block;
  }
  @media (max-width: 600px) { .cal-embed { height: 560px; } }

  @media (max-width: 880px) {
    .contact-layout { grid-template-columns: 1fr; }
  }
  @media (max-width: 520px) {
    .wa-row { grid-template-columns: 1fr; }
  }
</style>
